<Window x:Class="T021EnterPlacementPoc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:T021EnterPlacementPoc"
        Title="T-021 Enter配置フォーカス復帰 PoC" Height="640" Width="900"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">
    <DockPanel>
        <!-- 操作パネル: 明示Focus復帰トグル、自動ループ実行、ログクリア -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6">
            <CheckBox x:Name="ExplicitFocusRestore" Content="ダイアログ後にKeyboard.Focus(canvas)を明示復帰する"
                      IsChecked="True" VerticalAlignment="Center"/>
            <Button Content="自動ループ×3を実行" Click="RunAutoLoop_Click" Margin="16,0,0,0" Padding="8,2"/>
            <Button Content="ログclear" Click="ClearLog_Click" Margin="8,0,0,0" Padding="8,2"/>
        </StackPanel>

        <!-- ステータス: 現在のフォーカス所在をライブ表示 -->
        <Border DockPanel.Dock="Top" Background="#EEE" Padding="6">
            <TextBlock x:Name="FocusStatus" FontFamily="Consolas" Text="focus: (起動待ち)"/>
        </Border>

        <!-- 右: 検証ログ -->
        <Border DockPanel.Dock="Right" Width="320" BorderBrush="Gray" BorderThickness="1,0,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="検証ログ" FontWeight="Bold" Margin="4"/>
                <TextBox x:Name="LogBox" DockPanel.Dock="Bottom" IsReadOnly="True" FontFamily="Consolas"
                         FontSize="11" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         Focusable="False"/>
            </DockPanel>
        </Border>

        <!-- 手順ガイド -->
        <Border DockPanel.Dock="Bottom" Background="#F4F4F4" Padding="6">
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#333">
                手順(手動): (1)キャンバスをクリックしてフォーカス取得
                (2)矢印キーで選択セル移動 (3)Enterで配置→命名ダイアログ
                (4)名前入力しEnterで確定 (5)フォーカスがキャンバスに戻れば続けて矢印→Enterが効く。
                「自動ループ×3」でこの一連を3回自動実行し判定します。上のチェックで明示Focus復帰の有無を切替。
            </TextBlock>
        </Border>

        <!-- 中央: キャンバス(ScrollViewerでBringIntoView追従も後続増分で確認可能) -->
        <ScrollViewer x:Name="CanvasArea" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      FocusManager.IsFocusScope="True" Background="White">
            <local:PocCanvas x:Name="Canvas"/>
        </ScrollViewer>
    </DockPanel>
</Window>
