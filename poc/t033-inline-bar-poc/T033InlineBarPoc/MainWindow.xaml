<Window x:Class="T033InlineBarPoc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:T033InlineBarPoc"
        Title="T-033 非モーダル浮動インラインバー PoC" Height="640" Width="900"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid x:Name="RootGrid">
        <DockPanel>
            <!-- 操作パネル: 明示Focus復帰トグル、自動ループ実行、ログクリア -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6">
                <CheckBox x:Name="ExplicitFocusRestore" Content="バーを閉じた後にKeyboard.Focus(canvas)を明示復帰する"
                          IsChecked="True" VerticalAlignment="Center"/>
                <Button Content="自動ループ×3(OK確定)を実行" Click="RunAutoLoop_Click" Margin="16,0,0,0" Padding="8,2"/>
                <Button Content="Escキャンセル確認" Click="RunEscCancelCheck_Click" Margin="8,0,0,0" Padding="8,2"/>
                <Button Content="バー表示中F5無反応確認" Click="RunGlobalShortcutCheck_Click" Margin="8,0,0,0" Padding="8,2"/>
                <Button Content="ログclear" Click="ClearLog_Click" Margin="8,0,0,0" Padding="8,2"/>
            </StackPanel>

            <!-- ステータス: 現在のフォーカス所在をライブ表示 -->
            <Border DockPanel.Dock="Top" Background="#EEE" Padding="6">
                <TextBlock x:Name="FocusStatus" FontFamily="Consolas" Text="focus: (起動待ち)"/>
            </Border>

            <!-- 右: 検証ログ -->
            <Border DockPanel.Dock="Right" Width="380" BorderBrush="Gray" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="検証ログ" FontWeight="Bold" Margin="4"/>
                    <TextBox x:Name="LogBox" DockPanel.Dock="Bottom" IsReadOnly="True" FontFamily="Consolas"
                             FontSize="11" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                             Focusable="False"/>
                </DockPanel>
            </Border>

            <!-- 手順ガイド -->
            <Border DockPanel.Dock="Bottom" Background="#F4F4F4" Padding="6">
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#333">
                    手順(手動): (1)キャンバスクリックでフォーカス取得 (2)矢印でセル移動 (3)Enterで配置
                    →非モーダルバー(同一Window内オーバーレイ)が選択セル直下に浮動表示 (4)機器名を
                    入力しEnterで確定(OKボタンIsDefault経由を期待)またはEscで取消(キャンセルボタン
                    IsCancel経由を期待) (5)バーが閉じてキャンバスへフォーカスが戻れば続けて矢印移動が
                    効く。「バー表示中F5無反応確認」でグローバルショートカット(F5)がバー表示中に誤って
                    反応しないか(仮既定=モーダル同等に効かない)を確認する。
                </TextBlock>
            </Border>

            <!-- 中央: キャンバス -->
            <ScrollViewer x:Name="CanvasArea" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          FocusManager.IsFocusScope="True" Background="White">
                <local:PocCanvas x:Name="Canvas"/>
            </ScrollViewer>
        </DockPanel>

        <!-- 非モーダル浮動インラインバー本体(隠密所見により同一Window内オーバーレイ方式へ変更、
             docs/ecad2-t033-ui-automation-impact-survey-onmitsu.md参照)。RootGrid直下に重ね、
             位置はMarginで指定する(Popupの別HWNDに起因するWin32フォーカス懸念を構造的に回避)。
             GX Works3構想図に倣い横並び最小構成(種別選択は今回のPoCスコープ外につき省略)。 -->
        <Border x:Name="InlineBar" Background="White" BorderBrush="Gray" BorderThickness="1" Padding="6"
                HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="DeviceNameBox" Width="120" Margin="0,0,6,0" VerticalContentAlignment="Center"/>
                <Button x:Name="OkButton" Content="OK" Width="50" IsDefault="True" Click="OkButton_Click"/>
                <Button x:Name="CancelButton" Content="キャンセル" Width="64" Margin="6,0,0,0"
                        IsCancel="True" Click="CancelButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
