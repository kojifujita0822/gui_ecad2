<Window x:Class="T058AvalonDockPoc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:T058AvalonDockPoc"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        Title="T-058 AvalonDock導入前PoC" Height="700" Width="1100"
        ThemeMode="Dark">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <Button Content="レイアウト保存" Click="SaveLayout_Click" Padding="8,4" Margin="0,0,8,0"/>
            <Button Content="レイアウト復元" Click="LoadLayout_Click" Padding="8,4" Margin="0,0,8,0"/>
            <Button Content="既定レイアウトへ戻す" Click="ResetLayout_Click" Padding="8,4" Margin="0,0,8,0"/>
            <Button Content="左パレットをフロート化(検証用)" Click="FloatLeftPalette_Click" Padding="8,4" Margin="0,0,8,0"/>
            <Button Content="左パレットを再ドッキング(検証用)" Click="DockLeftPalette_Click" Padding="8,4" Margin="0,0,8,0"/>
            <Button Content="ツールパレットをフロート化(検証用)" Click="FloatToolPalette_Click" Padding="8,4" Margin="0,0,8,0"/>
            <Button Content="ツールパレットを再ドッキング(検証用)" Click="DockToolPalette_Click" Padding="8,4"/>
        </StackPanel>

        <avalonDock:DockingManager x:Name="DockManager" Grid.Row="1">
            <avalonDock:LayoutRoot x:Name="LayoutRootElement">
                <avalonDock:LayoutPanel Orientation="Horizontal">

                    <avalonDock:LayoutAnchorablePane DockWidth="150">
                        <avalonDock:LayoutAnchorable Title="ツールパレット(F5-F10相当)" ContentId="ToolPalette" CanClose="False">
                            <StackPanel Orientation="Vertical" Margin="4">
                                <Button Content="選択ツール" Margin="0,2" Padding="4"/>
                                <Button Content="F5 配置" Margin="0,2" Padding="4"/>
                                <Button Content="F6 配置" Margin="0,2" Padding="4"/>
                                <Button Content="F7 配置" Margin="0,2" Padding="4"/>
                                <Button Content="F8 配置" Margin="0,2" Padding="4"/>
                                <Button Content="F9 配置" Margin="0,2" Padding="4"/>
                                <Button Content="F10 配置" Margin="0,2" Padding="4"/>
                                <Button Content="部品" Margin="0,2" Padding="4"/>
                            </StackPanel>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                    <avalonDock:LayoutAnchorablePane DockWidth="200">
                        <avalonDock:LayoutAnchorable Title="左パレット(シートナビ相当)" ContentId="LeftPalette" CanClose="False">
                            <ListBox>
                                <ListBoxItem Content="シート1"/>
                                <ListBoxItem Content="シート2"/>
                                <ListBoxItem Content="シート3"/>
                            </ListBox>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                    <avalonDock:LayoutPanel Orientation="Vertical">
                        <avalonDock:LayoutDocumentPaneGroup>
                            <avalonDock:LayoutDocumentPane>
                                <avalonDock:LayoutDocument Title="作図キャンバス(PoC)" ContentId="Canvas" CanClose="False">
                                    <TextBlock Text="中央ドキュメント領域(作図キャンバス相当)" Margin="16" FontSize="16"/>
                                </avalonDock:LayoutDocument>
                            </avalonDock:LayoutDocumentPane>
                        </avalonDock:LayoutDocumentPaneGroup>

                        <avalonDock:LayoutAnchorablePane DockHeight="150">
                            <avalonDock:LayoutAnchorable Title="出力パネル(DRC結果相当)" ContentId="OutputPanel" CanClose="False">
                                <DataGrid AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="種別" Width="100"/>
                                        <DataGridTextColumn Header="内容" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                    </avalonDock:LayoutPanel>

                    <avalonDock:LayoutAnchorablePane DockWidth="250">
                        <avalonDock:LayoutAnchorable Title="右パネル(機器表/プロパティ相当)" ContentId="RightPanel" CanClose="False">
                            <StackPanel Margin="8">
                                <TextBlock Text="機器名: SW1" Margin="0,0,0,4"/>
                                <TextBlock Text="種別: セレクトSW" Margin="0,0,0,4"/>
                                <TextBlock Text="コメント: (PoCダミー表示)"/>
                            </StackPanel>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>

        <TextBlock x:Name="StatusText" Grid.Row="2" Margin="8" Text="準備完了。タブをドラッグして切り離す・右クリックでFloat/Dockを試せます。"/>
    </Grid>
</Window>
