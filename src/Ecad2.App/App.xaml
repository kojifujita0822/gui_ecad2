<Application x:Class="Ecad2.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Ecad2.App"
             xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!--
            T-083増分2(家老采配2026-07-16): 4ブラシ(GX Works3実機調査T-012由来、うち3つは元々
            ここに直接定義されていた)をTheme.Light.xaml/Theme.Dark.xamlへ統合し、IsDarkMode変更時
            にMergedDictionariesを差し替える方式(MainWindow.xaml.cs ApplyUiChromeTheme参照)へ移行。
            起動時既定はライトモード(殿裁定)のためTheme.Light.xamlを既定で読み込む。
        -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Theme.Light.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- T-083増分5(家老采配2026-07-17): ペイン内ListBox/DataGridの暗黙的スタイル。
                 対象コントロールはMainWindow.xaml内5箇所(SheetNavList/DeviceTableGrid/
                 FindResultsGrid/OutputGrid/PartSelectionList)のみ(Explore確認済み)。
                 既存ItemContainerStyle/RowStyleを個別指定済みの箇所はBasedOnで継承する。 -->
            <!-- T-100新規発見6対応(殿裁定2026-07-21、方式1=ControlTemplate差し替え、
                 docs/ecad2-t100-shinki6-root-cause-onmitsu.md): 上記暗黙的スタイルはTemplate
                 未設定のためWPF既定Aero2 ControlTemplateをそのまま継承していたが、既定テンプレート
                 の`IsEnabled=false`トリガーがBackground/BorderBrushを白固定色(StaticResource、
                 PR-20パターン1と同型)へ強制上書きするため、配置バー表示中等(MainContentArea無効化)
                 にSheetNavList/PartSelectionListが持続的に白化していた。Template新設(一次ソース
                 dotnet/wpf Aero2.NormalColor.xaml 2524-2565行のBorder+ScrollViewer+ItemsPresenter
                 構造を踏襲)し、IsEnabled=falseトリガーのBackground/BorderBrushを通常時と同じ
                 DynamicResourceへ差し替える(無効化時も見た目を保つ、殿裁定の主旨)。Template新設に
                 伴い失われるStyle本体の既定値Setter群(BorderBrush/BorderThickness/ScrollViewer.*/
                 Stylus.IsFlicksEnabled/VerticalContentAlignment)も一次ソースどおり移植する
                 (PR-21の教訓、T-089/T-106踏襲)。BorderBrushは既存DataGrid系と一貫させ
                 PanelGridLineBrushを採用(新規キー追加を避ける)。 -->
            <Style TargetType="{x:Type ListBox}">
                <Setter Property="Background" Value="{DynamicResource PanelContentBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelContentForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PanelGridLineBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
                <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
                <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBox}">
                            <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="true"
                                Padding="1">
                                <ScrollViewer Padding="{TemplateBinding Padding}" Focusable="false">
                                    <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </ScrollViewer>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="false">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelContentBackgroundBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PanelGridLineBrush}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsGrouping" Value="true"/>
                                        <Condition Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="false"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- T-083見落とし修正(家老采配2026-07-19、殿報告=ライトモードで新規シート名が
                 白背景×白文字で視認不能): 既定ListBoxItemのControlTemplate(Aero2、
                 dotnet/wpf一次ソース確認済み)はIsSelected=True時、Selector.IsSelectionActive
                 (フォーカスの有無)で異なるBackground(TargetName="Bd"指定Setter、優先度4位)を
                 出し分けるMultiTriggerを持つ。旧実装のStyle.TriggersのBackground Setter
                 (TargetName無し、優先度6位)はこれに常に負けるため、フォーカス無し選択時
                 (モーダルダイアログ経由のシート追加・リネーム直後等)は既定の非アクティブ選択色
                 (薄いグレー系)にフォールバックしていた。一方Foreground(コントロール自身の
                 プロパティ、既定テンプレート側は変更しない)はStyle.Trigger側がそのまま効くため、
                 フォーカス無し選択時に「薄い背景×選択用の明るい文字色」という組み合わせになり、
                 ライトモードでは実質視認不能になっていた(PR-20型(3)と同型の罠、T-089と同じ
                 「既定コピー+標的差し替え」手法で対処する)。IsSelectionActiveの2つのMultiTrigger
                 を、フォーカスの有無を問わないIsSelected単一トリガーへ統合し、Background/
                 Foregroundとも常にPanelContentSelected*Brushへ揃える(ecad2の配色方針として、
                 フォーカス有無による選択色の使い分けは行わない)。
                 【往復2周目(隠密静的レビュー指摘、家老采配2026-07-19)】PR-21確定(2件目)への追補:
                 旧実装は暗黙的スタイルがTemplate未設定ゆえ、Aero2テーマ既定のStyle本体Setter群と
                 テンプレート内MouseOverトリガーが下位優先度で生きていた(「存在しなかった」は誤認)。
                 Template新設で消えた分を一次ソース(dotnet/wpf Aero2.NormalColor.xaml 2581-2635行)
                 どおり移植する: (a)MouseOverトリガー(色は既定テーマの実値#1F26A0DA/#a826A0Da、
                 従来の見た目の完全復元。選択トリガーより前に置き、選択中は選択背景が勝つ既定の
                 優先順位を保つ) (b)Style本体の既定値Setter群(SnapsToDevicePixels/Padding/
                 両ContentAlignment Binding/BorderThickness/FocusVisualStyle。FocusVisualStyleの
                 参照先は既定テーマの難読化キーゆえ直接参照できず、同内容を
                 ListBoxItemFocusVisualStyleとして複製定義)。 -->
            <Style x:Key="ListBoxItemFocusVisualStyle">
                <Setter Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Rectangle Margin="2" SnapsToDevicePixels="true" Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" StrokeThickness="1" StrokeDashArray="1 2"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="{x:Type ListBoxItem}">
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Padding" Value="4,1"/>
                <Setter Property="HorizontalContentAlignment" Value="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"/>
                <Setter Property="VerticalContentAlignment" Value="{Binding VerticalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"/>
                <!-- 往復3周目(殿裁可): Background未設定だと余白部分がヒットテストをすり抜け
                     クリックが背後へ届く(WPF既知の仕様、Transparent明示でヒットテスト有効)。
                     一次ソース2586-2587行どおり移植。 -->
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource ListBoxItemFocusVisualStyle}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="Bd"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="#1F26A0DA"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#a826A0Da"/>
                                </MultiTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelContentSelectedBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PanelContentSelectedForegroundBrush}"/>
                                </Trigger>
                                <!-- 新規発見(2026-07-20、殿発見バグ・忍者実測・隠密俯瞰評価): 一次ソース
                                     (dotnet/wpf Aero2.NormalColor.xaml 2628-2630行)のIsEnabled=Falseトリガーは
                                     TargetName="Bd"(内側Border)へTextElement.Foregroundを設定するが、Aero2本体は
                                     選択時にForegroundを変更しない(Background/BorderBrushのみ)ため矛盾しない。
                                     ecad2は選択項目の視認性向上のため独自にIsSelectedトリガーへForeground変更
                                     (TargetName無し=ListBoxItem自身)を追加しており、両トリガーが同時に真の場合、
                                     依存関係プロパティの継承則により内側(Bd)の設定が外側(ListBoxItem自身)より
                                     優先されグレー文字が勝ってしまっていた(選択操作中に配置ダイアログ表示等で
                                     MainContentArea全体が無効化されると発生)。殿裁定=選択中は無効化時も文字を
                                     見やすいまま保つ、によりMultiTrigger化しIsSelected=Trueの場合を除外する。 -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsEnabled" Value="False"/>
                                        <Condition Property="IsSelected" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="TextElement.Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- T-108追加修正(家老采配2026-07-21、隠密全体点検PR-24第2例): StatusBar用の暗黙的スタイルが
                 ecad2側に存在せず、Aero2既定テーマスタイル本体のBackground(固定薄灰#FFF1EDED)・
                 Foreground({DynamicResource SystemColors.ControlTextBrushKey}、OS設定準拠で固定に近い)
                 がそのまま適用され、ステータスバー7項目が常時ライトモード風配色のままだった
                 (一次ソースdotnet/wpf Aero2.NormalColor.xaml 5377-5458行で確認済み)。既定Template
                 (Border+ItemsPresenter/ContentPresenter)はTemplateBinding経由でBackground/Foreground
                 を継承するのみのシンプルな構造のため、Template自体は新設せずStyle.Setterのみで
                 十分(DataGridと同型、RadioButton(T-108先行修正)と同一メカニズム=PR-24)。 -->
            <Style TargetType="{x:Type StatusBar}">
                <Setter Property="Background" Value="{DynamicResource ToolBarBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ToolBarForegroundBrush}"/>
            </Style>
            <Style TargetType="{x:Type StatusBarItem}">
                <Setter Property="Foreground" Value="{DynamicResource ToolBarForegroundBrush}"/>
            </Style>

            <Style TargetType="{x:Type DataGrid}">
                <Setter Property="Background" Value="{DynamicResource PanelContentBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelContentForegroundBrush}"/>
                <Setter Property="RowBackground" Value="{DynamicResource PanelContentBackgroundBrush}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource PanelGridLineBrush}"/>
                <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource PanelGridLineBrush}"/>
            </Style>
            <Style TargetType="{x:Type DataGridRow}">
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PanelContentSelectedBackgroundBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PanelContentSelectedForegroundBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="{x:Type DataGridColumnHeader}">
                <Setter Property="Background" Value="{DynamicResource PanelHeaderBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelHeaderForegroundBrush}"/>
            </Style>

            <!-- T-083増分5欠陥修正(家老采配2026-07-17、隠密静的レビューCONFIRMED指摘):
                 WPF既定のDataGridCell(全テーマ共通の暗黙的Style)はIsSelected=True時に
                 SystemColors.HighlightBrushKey(OSアクセントカラー)でBackground/Foreground/
                 BorderBrushを上書きするTriggerを持つ(dotnet/wpf DataGrid.xaml 308-341行、
                 一次ソース裏取り済み)。セルが行のほぼ全面を前面描画するため、DataGridRowへの
                 IsSelectedトリガーのみでは選択行の背景がOSアクセントカラーのまま残ってしまう。
                 DataGridCell自体にも同様のIsSelectedトリガーを追加して対処する
                 (ListBoxItemは単層構造のためこの問題は生じず対象外)。 -->
            <Style TargetType="{x:Type DataGridCell}">
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PanelContentSelectedBackgroundBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PanelContentSelectedForegroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource PanelContentSelectedBackgroundBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- T-089叩き台(家老采配2026-07-17、着手前調査書=docs/ecad2-t089-button-style-survey-onmitsu.md):
                 ボタン押下状態の視覚的明示化。App.xamlのApplication.Resourcesへ暗黙的スタイル
                 (TargetType=Button/ToggleButton)を新設し、MainWindow.xamlの既存3スタイルを
                 BasedOnさせる構成に変更(構造変更、調査書の結論通り)。これによりMainWindow内の
                 名前付きスタイル使用ボタン(23個)だけでなく、ダイアログ6ファイル・MainWindow内の
                 スタイル指定なしボタン(計30個超)にも自動的に反映される。
                 押下時の具体的な視覚表現はUI/UX分岐のため殿確認が必須(T-089節、T-048と同型の
                 進め方)。本スタイルは【案A: 半透明オーバーレイ型】——IsPressed=True時に
                 半透明の黒(#33000000)をBackgroundへ重ねる。テーマ非依存(Light/Dark双方の
                 既存背景色の上で自然に暗くなる)で、Material Design等で一般的な「状態レイヤー」
                 の簡易版。 -->
            <!-- T-089対処(2026-07-18、隠密一次ソース調査確定=docs/ecad2-t089-button-pressed-feedback-investigation-onmitsu.md):
                 上記Style.Triggers方式は原理的に対処不能と判明。既定Aero2 ControlTemplate
                 (dotnet/wpf Button.xaml BaseButtonStyle、TargetType=ButtonBase)内の
                 ControlTemplate.Triggers(TargetName="border"直接Setter、WPF依存関係プロパティ値
                 優先順位で4位)が、Style.Triggers(6位)を完全に握り潰すため(公式ドキュメントが
                 同型の罠を明記=PR-20(3))、増分7(SubMenuBorder)と同型のアプローチ=既定
                 ControlTemplateをコピーし、専用オーバーレイ矩形(PressedOverlay)を追加する方式へ
                 変更。既存の色変化ロジック(MouseOver/Pressed/Checked/Disabled、TargetName="border"
                 のBackground/BorderBrush Setter)自体は元のStaticResourceキー参照のまま温存し、
                 押下時のみ半透明黒(#33000000)を追加で重ねる(案Aの意図=既存背景色の上に暗くする、
                 を保つ)。 -->
            <!-- T-089 Stack overflow修正(2026-07-18、忍者crash.log+隠密キー調査の突合で確定):
                 真因は2段構え——(1)本テンプレートが参照するButton.*キー7種はWPF Aero2テーマDLL内部
                 のリソースであり、アプリのリソース検索スコープからは解決できない(ControlTemplate
                 .Triggers内のStaticResourceは遅延解決のため、ビルド時・XAML解析時エラーにならず
                 トリガー発火時にUnsetValueとして現れる) (2)暗黙的StyleがテーマStyleを置き換えた
                 ことで、テーマStyle側が持っていたBackground/BorderBrush等の既定値Setterも失われ、
                 TemplateBinding経由でBorder要素へUnsetValueが渡る。起動直後はHasProject=falseで
                 多数のボタンがIsEnabled=falseトリガーを発火させるため即クラッシュに至った
                 (Border.ArrangeOverride内InvalidOperationException→OnDispatcherUnhandledException
                 のMessageBox.Show→UpdateLayout→再発の無限ループ→Stack overflow)。
                 対処=7キーをecad2側で明示定義(色値はdotnet/wpf main「Button.xaml」Aero2.NormalColor
                 の既定値を転記)し、Style既定値Setter群(テーマStyle相当)も併せて定義する。 -->
            <SolidColorBrush x:Key="Button.Static.Background" Color="#FFDDDDDD"/>
            <SolidColorBrush x:Key="Button.Static.Border" Color="#FF707070"/>
            <SolidColorBrush x:Key="Button.MouseOver.Background" Color="#FFBEE6FD"/>
            <SolidColorBrush x:Key="Button.MouseOver.Border" Color="#FF3C7FB1"/>
            <SolidColorBrush x:Key="Button.Pressed.Background" Color="#FFC4E5F6"/>
            <SolidColorBrush x:Key="Button.Pressed.Border" Color="#FF2C628B"/>
            <SolidColorBrush x:Key="Button.Checked.Background" Color="#FFBCDDEE"/>
            <SolidColorBrush x:Key="Button.Checked.Border" Color="#FF245A83"/>
            <SolidColorBrush x:Key="Button.Disabled.Background" Color="#FFF4F4F4"/>
            <SolidColorBrush x:Key="Button.Disabled.Border" Color="#FFADB2B5"/>

            <Style TargetType="{x:Type Button}">
                <Setter Property="Background" Value="{StaticResource Button.Static.Background}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Button.Static.Border}"/>
                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="border"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                SnapsToDevicePixels="true">
                                <Grid>
                                    <ContentPresenter x:Name="contentPresenter"
                                        Focusable="False"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        Margin="{TemplateBinding Padding}"
                                        RecognizesAccessKey="True"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    <Rectangle x:Name="PressedOverlay" Fill="#33000000" IsHitTestVisible="False" Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- 状態別の背景/枠線はすべてStyle.Triggers側(下記)へ移設(T-089、
                                     2026-07-18): ControlTemplate.Triggers(優先度4位)に置くと
                                     ツールバー系派生スタイルのStyle.Triggers(6位)を握り潰す罠が
                                     IsEnabled(無効ボタン明灰色)・IsChecked(テストモードON色化け)で
                                     2連続再発したため、テンプレートには構造のみ(PressedOverlay
                                     表示・無効文字色=TargetName必須のもの)を残す。 -->
                                <Trigger Property="IsPressed" Value="true">
                                    <Setter Property="Visibility" Value="Visible" TargetName="PressedOverlay"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="false">
                                    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" TargetName="contentPresenter"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <!-- 状態別の背景/枠線(優先度6位=派生スタイルで上書き可能)。順序はAero2既定に
                     倣いIsDefaulted→MouseOver→Pressed→Disabled(後勝ちのため無効表示が最優先)。 -->
                <Style.Triggers>
                    <Trigger Property="Button.IsDefaulted" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource Button.MouseOver.Background}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Button.MouseOver.Border}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource Button.Pressed.Background}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Button.Pressed.Border}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="{StaticResource Button.Disabled.Background}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Button.Disabled.Border}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="{x:Type ToggleButton}">
                <!-- T-089 Stack overflow修正(2026-07-18、Button側と同根): テーマStyle置き換えに伴い
                     失われた既定値Setter群を明示定義する(上記Button側コメント参照)。 -->
                <Setter Property="Background" Value="{StaticResource Button.Static.Background}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Button.Static.Border}"/>
                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Border x:Name="border"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                SnapsToDevicePixels="true">
                                <Grid>
                                    <ContentPresenter x:Name="contentPresenter"
                                        Focusable="False"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        Margin="{TemplateBinding Padding}"
                                        RecognizesAccessKey="True"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    <Rectangle x:Name="PressedOverlay" Fill="#33000000" IsHitTestVisible="False" Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Button側と同じく、状態別の背景/枠線はすべてStyle.Triggers側へ
                                     移設(T-089忍者実機NG 2026-07-18: テンプレート側に置くと優先度
                                     4位となりTestModeToolBarButtonStyleのIsCheckedトリガー
                                     [TestModeActiveBrush、優先度6位]を握り潰し、テストモードON色が
                                     水色#BCDDEEに化けた)。テンプレートには構造のみ残す。 -->
                                <Trigger Property="IsPressed" Value="true">
                                    <Setter Property="Visibility" Value="Visible" TargetName="PressedOverlay"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="false">
                                    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" TargetName="contentPresenter"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <!-- Button側と同じ理由(派生スタイルによる上書き可能化)でStyle.Triggersに置く。
                     順序はMouseOver→Pressed→Checked→Disabled(Aero2既定に倣う。後勝ちのため
                     無効表示が最優先、チェック済みはホバー/押下より優先)。 -->
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource Button.MouseOver.Background}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Button.MouseOver.Border}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource Button.Pressed.Background}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Button.Pressed.Border}"/>
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Background" Value="{StaticResource Button.Checked.Background}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Button.Checked.Border}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="{StaticResource Button.Disabled.Background}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Button.Disabled.Border}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- T-106(5)スコープ拡大(殿裁定2026-07-21、docs/todo.md T-106節): 種別選択ドロップダウン
                 (PlacementPartComboBox)がApp.xaml側にComboBox専用の暗黙的スタイルが存在せずWPF既定
                 Aero2テーマそのままでダークモード非対応だった欠落を修正する。既定Aero2 ComboBox
                 (dotnet/wpf Themes/XAML/ComboBox.xaml、Aero2.NormalColorセクション)のControlTemplate
                 構造を踏襲しつつ、色のみDynamicResource化する(T-089/T-099と同型の「既定コピー+
                 標的差し替え」手法)。MouseOver/Pressed/Disabled色は既存Button.*(本ファイル上部、
                 テーマ非依存のツールバー配色)を流用し新規キー追加を避ける。DropShadowChrome
                 (ドロップシャドウ演出)・OpaqueRect(半透明背景対策、DropDownBorderに不透明色を
                 明示指定済みのため不要)は意匠の細部のため簡略化して省く。 -->
            <Style x:Key="EcadComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="IsTabStop" Value="false"/>
                <Setter Property="Focusable" Value="false"/>
                <Setter Property="ClickMode" Value="Press"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Border x:Name="templateRoot" SnapsToDevicePixels="true"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Background="{TemplateBinding Background}">
                                <Border x:Name="splitBorder" HorizontalAlignment="Right"
                                    Width="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}"
                                    Margin="0">
                                    <Path x:Name="Arrow" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Fill="{DynamicResource ToolBarForegroundBrush}"
                                        Data="M 0,0 L 3.5,4 L 7,0 Z"/>
                                </Border>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter TargetName="templateRoot" Property="Background" Value="{StaticResource Button.MouseOver.Background}"/>
                                    <Setter TargetName="templateRoot" Property="BorderBrush" Value="{StaticResource Button.MouseOver.Border}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="true">
                                    <Setter TargetName="templateRoot" Property="Background" Value="{StaticResource Button.Pressed.Background}"/>
                                    <Setter TargetName="templateRoot" Property="BorderBrush" Value="{StaticResource Button.Pressed.Border}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="false">
                                    <Setter TargetName="templateRoot" Property="Background" Value="{StaticResource Button.Disabled.Background}"/>
                                    <Setter TargetName="templateRoot" Property="BorderBrush" Value="{StaticResource Button.Disabled.Border}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <ControlTemplate x:Key="EcadComboBoxTemplate" TargetType="{x:Type ComboBox}">
                <Grid x:Name="templateRoot" SnapsToDevicePixels="true">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition MinWidth="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}" Width="0"/>
                    </Grid.ColumnDefinitions>
                    <Popup x:Name="PART_Popup" AllowsTransparency="true" Margin="1" Placement="Bottom" Grid.ColumnSpan="2"
                        IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                        PopupAnimation="{DynamicResource {x:Static SystemParameters.ComboBoxPopupAnimationKey}}">
                        <Border x:Name="DropDownBorder"
                            MinWidth="{Binding ActualWidth, ElementName=templateRoot}"
                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                            BorderBrush="{DynamicResource DialogBorderBrush}"
                            Background="{DynamicResource PanelContentBackgroundBrush}"
                            BorderThickness="1">
                            <ScrollViewer Name="DropDownScrollViewer">
                                <ItemsPresenter Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                    <ToggleButton x:Name="toggleButton"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        Background="{TemplateBinding Background}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                        Style="{StaticResource EcadComboBoxToggleButton}"
                        Grid.ColumnSpan="2" />
                    <ContentPresenter x:Name="contentPresenter"
                        Content="{TemplateBinding SelectionBoxItem}"
                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                        ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                        ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                        IsHitTestVisible="false"
                        Margin="{TemplateBinding Padding}"
                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="HasItems" Value="false">
                        <Setter TargetName="DropDownBorder" Property="MinHeight" Value="20"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="false">
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <Style TargetType="{x:Type ComboBox}">
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Button.Static.Border}"/>
                <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6,3,5,3"/>
                <Setter Property="Template" Value="{StaticResource EcadComboBoxTemplate}"/>
            </Style>

            <Style TargetType="{x:Type ComboBoxItem}">
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Padding" Value="4,1"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelContentForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                            <Border x:Name="Bd"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Button.MouseOver.Background}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Button.MouseOver.Border}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelContentSelectedBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PanelContentSelectedForegroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- T-106(7)スコープ再拡大(殿裁定2026-07-21、docs/todo.md T-106節): スクロールバー全般が
                 App.xaml側にScrollBar専用の暗黙的スタイルが存在せずWPF既定Aero2テーマそのままで
                 ダークモード非対応だった欠落を修正する(通常WPFコントロール=シートパネル一覧・
                 DataGrid等のScrollBarが対象、AvalonDock/VS2013テーマ側で別途対応済みの箇所は対象外)。
                 既定Aero2 ScrollBar(RepeatButton×2+Track+Thumb)のControlTemplate構造を踏襲しつつ、
                 色のみDynamicResource化する。矢印の押下フィードバック(黒/白切替)・Thumbの
                 MouseOver/Dragging別色等、意匠の細部はダークモード対応の主旨に対して過剰なため
                 単純化する(矢印色は固定・Thumbの2状態は1色に統合)。 -->
            <Style x:Key="EcadScrollBarLineButton" TargetType="{x:Type RepeatButton}">
                <Setter Property="Focusable" Value="false"/>
                <Setter Property="IsTabStop" Value="false"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                            <Border x:Name="border" Background="Transparent" SnapsToDevicePixels="true">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ScrollBarButtonHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="true">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ScrollBarButtonHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="EcadScrollBarPageButton" TargetType="{x:Type RepeatButton}">
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="Focusable" Value="false"/>
                <Setter Property="IsTabStop" Value="false"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                            <Rectangle Fill="Transparent"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="EcadScrollBarThumb" TargetType="{x:Type Thumb}">
                <Setter Property="IsTabStop" Value="false"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Rectangle x:Name="rectangle" SnapsToDevicePixels="True"
                                Fill="{DynamicResource ScrollBarThumbBrush}"
                                Height="{TemplateBinding Height}" Width="{TemplateBinding Width}"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter TargetName="rectangle" Property="Fill" Value="{DynamicResource ScrollBarThumbHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="true">
                                    <Setter TargetName="rectangle" Property="Fill" Value="{DynamicResource ScrollBarThumbHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="{x:Type ScrollBar}">
                <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
                <Setter Property="Background" Value="{DynamicResource ToolBarBackgroundBrush}"/>
                <Setter Property="Width" Value="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}"/>
                <Setter Property="MinWidth" Value="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid SnapsToDevicePixels="true">
                                <Grid.RowDefinitions>
                                    <RowDefinition MaxHeight="{DynamicResource {x:Static SystemParameters.VerticalScrollBarButtonHeightKey}}"/>
                                    <RowDefinition Height="0.00001*"/>
                                    <RowDefinition MaxHeight="{DynamicResource {x:Static SystemParameters.VerticalScrollBarButtonHeightKey}}"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="1" Background="{TemplateBinding Background}"/>
                                <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}" Style="{StaticResource EcadScrollBarLineButton}">
                                    <Path Data="M 0,4 L 3.5,0.5 L 7,4" Stretch="Uniform" Width="7" Height="4" Margin="3" Fill="{DynamicResource ToolBarForegroundBrush}"/>
                                </RepeatButton>
                                <Track x:Name="PART_Track" IsDirectionReversed="true" Grid.Row="1">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource EcadScrollBarPageButton}"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource EcadScrollBarPageButton}"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource EcadScrollBarThumb}"/>
                                    </Track.Thumb>
                                </Track>
                                <RepeatButton Grid.Row="2" Command="{x:Static ScrollBar.LineDownCommand}" Style="{StaticResource EcadScrollBarLineButton}">
                                    <Path Data="M 0,0 L 3.5,4 L 7,0" Stretch="Uniform" Width="7" Height="4" Margin="3" Fill="{DynamicResource ToolBarForegroundBrush}"/>
                                </RepeatButton>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="MinWidth" Value="0"/>
                        <Setter Property="Height" Value="{DynamicResource {x:Static SystemParameters.HorizontalScrollBarHeightKey}}"/>
                        <Setter Property="MinHeight" Value="{DynamicResource {x:Static SystemParameters.HorizontalScrollBarHeightKey}}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ScrollBar}">
                                    <Grid SnapsToDevicePixels="true">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition MaxWidth="{DynamicResource {x:Static SystemParameters.HorizontalScrollBarButtonWidthKey}}"/>
                                            <ColumnDefinition Width="0.00001*"/>
                                            <ColumnDefinition MaxWidth="{DynamicResource {x:Static SystemParameters.HorizontalScrollBarButtonWidthKey}}"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="1" Background="{TemplateBinding Background}"/>
                                        <RepeatButton Command="{x:Static ScrollBar.LineLeftCommand}" Style="{StaticResource EcadScrollBarLineButton}">
                                            <Path Data="M 5,0 L 0,3.5 L 5,7" Stretch="Uniform" Width="5" Height="7" Margin="3" Fill="{DynamicResource ToolBarForegroundBrush}"/>
                                        </RepeatButton>
                                        <Track x:Name="PART_Track" Grid.Column="1">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Style="{StaticResource EcadScrollBarPageButton}"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Style="{StaticResource EcadScrollBarPageButton}"/>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource EcadScrollBarThumb}"/>
                                            </Track.Thumb>
                                        </Track>
                                        <RepeatButton Grid.Column="2" Command="{x:Static ScrollBar.LineRightCommand}" Style="{StaticResource EcadScrollBarLineButton}">
                                            <Path Data="M 0,0 L 5,3.5 L 0,7" Stretch="Uniform" Width="5" Height="7" Margin="3" Fill="{DynamicResource ToolBarForegroundBrush}"/>
                                        </RepeatButton>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- T-083増分7(家老采配2026-07-17、隠密調査書=docs/ecad2-t083-zoubun7-menu-dark-redesign-survey-onmitsu.md):
                 ドロップダウンメニューのダーク対応。根本原因はWPF既定(Aero2)MenuItemテンプレート内
                 SubMenuBorder(ポップアップ全体の背景)がStaticResource参照のためDynamicResource
                 オーバーライドが原理的に届かない構造的制約(検証ミスではない、調査書1.2節)。
                 対処: 既定テンプレートをComponentResourceKeyで同一キー上書きする「派生テンプレート」
                 (完全自作ではなく色参照のみDynamicResource化、形状・レイアウトは既定を踏襲)。
                 既定WPFのMenuItem Style自体がTemplateプロパティをDynamicResourceでこのキー経由で
                 参照する仕組みのため、ここでキーを定義するだけで既定StyleのRole切替ロジック
                 (TopLevelHeader/TopLevelItem/SubmenuHeader/既定=SubmenuItem)は変更せずに済む。
                 対象2種のみ(家老裁量2026-07-17): 現行メニュー構造(MainWindow.xaml)は2階層のみで
                 サブサブメニューを持たないため、TopLevelItemTemplateKey・SubmenuHeaderTemplateKeyは
                 現状未使用につき省略。
                 チェックマーク形状は既定テーマ内蔵Geometry(Checkmark)がテーマDLL外から参照不能の
                 ためStroke形状で代替(色のみがテーマ対応の本旨、意匠は技術判断の範囲)。
                 実装順序【重要】: このドロップダウン側を先に定義し、MainWindow.xamlのMenuBarArea
                 のBackground/Foreground復活は後で行う(逆順だと増分7初回打ち切り時と同じ
                 「白地に白文字」が再発する、調査書5節)。 -->
            <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="{x:Type Separator}">
                <Setter Property="Background" Value="{DynamicResource MenuSeparatorBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource MenuSeparatorBrush}"/>
                <Setter Property="MinHeight" Value="1"/>
                <Setter Property="SnapsToDevicePixels" Value="true"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Separator}">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="30,0,0,0"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <ControlTemplate x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type MenuItem}, ResourceId=TopLevelHeaderTemplateKey}" TargetType="{x:Type MenuItem}">
                <Border x:Name="templateRoot"
                    SnapsToDevicePixels="true"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter x:Name="Icon"
                            ContentSource="Icon"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="16" Height="16" Margin="3"/>
                        <Path x:Name="GlyphPanel"
                            Data="M 1,5 L 4,8 L 9,1"
                            Stroke="{DynamicResource MenuBarForegroundBrush}"
                            StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                            FlowDirection="LeftToRight"
                            Margin="3"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"/>
                        <ContentPresenter
                            Grid.Column="1"
                            ContentSource="Header"
                            RecognizesAccessKey="True"
                            Margin="{TemplateBinding Padding}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        <Popup x:Name="PART_Popup"
                            AllowsTransparency="true"
                            Focusable="false"
                            IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                            PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=templateRoot}">
                            <Border x:Name="SubMenuBorder"
                                Background="{DynamicResource MenuBarBackgroundBrush}"
                                BorderBrush="{DynamicResource MenuPopupBorderBrush}"
                                BorderThickness="1" Padding="2">
                                <ScrollViewer x:Name="SubMenuScrollViewer"
                                    Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                    <Grid RenderOptions.ClearTypeHint="Enabled">
                                        <Canvas Height="0" Width="0" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <Rectangle Name="OpaqueRect"
                                                Height="{Binding ElementName=SubMenuBorder,Path=ActualHeight}"
                                                Width="{Binding ElementName=SubMenuBorder,Path=ActualWidth}"
                                                Fill="{Binding ElementName=SubMenuBorder,Path=Background}"/>
                                        </Canvas>
                                        <Rectangle HorizontalAlignment="Left" Width="1" Margin="29,2,0,2"
                                            Fill="{DynamicResource MenuSeparatorBrush}"/>
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                            KeyboardNavigation.DirectionalNavigation="Cycle"
                                            KeyboardNavigation.TabNavigation="Cycle"
                                            Grid.IsSharedSizeScope="true"
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsSuspendingPopupAnimation" Value="true">
                        <Setter TargetName="PART_Popup" Property="PopupAnimation" Value="None"/>
                    </Trigger>
                    <Trigger Property="Icon" Value="{x:Null}">
                        <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                    </Trigger>
                    <Trigger Property="IsChecked" Value="true">
                        <Setter TargetName="GlyphPanel" Property="Visibility" Value="Visible"/>
                        <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                    </Trigger>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource MenuItemAccentBackgroundBrush}"/>
                        <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource MenuItemAccentBorderBrush}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="templateRoot" Property="TextElement.Foreground" Value="{DynamicResource MenuDisabledForegroundBrush}"/>
                        <Setter TargetName="GlyphPanel" Property="Stroke" Value="{DynamicResource MenuDisabledForegroundBrush}"/>
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsHighlighted" Value="True"/>
                            <Condition Property="IsEnabled" Value="False"/>
                        </MultiTrigger.Conditions>
                        <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource MenuItemHighlightDisabledBackgroundBrush}"/>
                        <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource MenuItemHighlightDisabledBorderBrush}"/>
                    </MultiTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <ControlTemplate x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type MenuItem}, ResourceId=SubmenuItemTemplateKey}" TargetType="{x:Type MenuItem}">
                <Border x:Name="templateRoot"
                    SnapsToDevicePixels="true"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}">
                    <Grid Margin="-1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition MinWidth="22" SharedSizeGroup="MenuItemIconColumnGroup" Width="Auto"/>
                            <ColumnDefinition Width="13"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition SharedSizeGroup="MenuItemIGTColumnGroup" Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter x:Name="Icon"
                            ContentSource="Icon"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="16" Height="16" Margin="3"/>
                        <Border x:Name="GlyphPanel"
                            Visibility="Hidden"
                            Height="22" Width="22"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource MenuItemAccentBackgroundBrush}"
                            BorderBrush="{DynamicResource MenuItemAccentBorderBrush}"
                            BorderThickness="1"
                            ClipToBounds="False"
                            Margin="-1,0,0,0">
                            <Path x:Name="Glyph"
                                Data="M 1,5 L 4,8 L 9,1"
                                Stroke="{DynamicResource MenuBarForegroundBrush}"
                                StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                FlowDirection="LeftToRight"
                                Height="11" Width="10"/>
                        </Border>
                        <ContentPresenter x:Name="menuHeaderContainer"
                            Grid.Column="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            ContentSource="Header"
                            RecognizesAccessKey="True"
                            Margin="{TemplateBinding Padding}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        <TextBlock x:Name="menuGestureText"
                            Grid.Column="4"
                            Text="{TemplateBinding InputGestureText}"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Center"
                            Opacity="0.7"/>
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="Icon" Value="{x:Null}">
                        <Setter Property="Visibility" TargetName="Icon" Value="Collapsed"/>
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="GlyphPanel" Property="Visibility" Value="Visible"/>
                        <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                    </Trigger>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource MenuItemAccentBackgroundBrush}"/>
                        <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource MenuItemAccentBorderBrush}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="templateRoot" Property="TextElement.Foreground" Value="{DynamicResource MenuDisabledForegroundBrush}"/>
                        <Setter TargetName="Glyph" Property="Stroke" Value="{DynamicResource MenuDisabledForegroundBrush}"/>
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsHighlighted" Value="True"/>
                            <Condition Property="IsEnabled" Value="False"/>
                        </MultiTrigger.Conditions>
                        <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource MenuItemHighlightDisabledBackgroundBrush}"/>
                        <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource MenuItemHighlightDisabledBorderBrush}"/>
                    </MultiTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
