<Application x:Class="Ecad2.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Ecad2.App"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!--
            GX Works3実機調査(T-012)より: 配色は状態依存。
            空状態(プロジェクト未作成)=濃紺、作業領域(ラダーエディタ内部)=白+黒グリッド。
            グリッド色はEcad2.Core.Rendering.DrawingTheme.GridGray(#D2D2D2)と一貫させる。
        -->
        <!-- 濃紺の明度調整(殿裁定2026-07-05): #1E2A47→#24325A(「ほんの少しだけ明るく」)。 -->
        <SolidColorBrush x:Key="EmptyStateBackgroundBrush" Color="#24325A"/>
        <SolidColorBrush x:Key="WorkAreaBackgroundBrush" Color="White"/>
        <SolidColorBrush x:Key="WorkAreaGridBrush" Color="#D2D2D2"/>
        <!-- T-061: テストモードON中のツールバートグルボタン背景。Ecad2.Core.Rendering.DrawingTheme.Powered
             (通電/励磁の意味色、RGB 230,60,0)と同一色を流用し、テストモード全体を象徴する色として一貫させる。 -->
        <SolidColorBrush x:Key="TestModeActiveBrush" Color="#E63C00"/>
    </Application.Resources>
</Application>
