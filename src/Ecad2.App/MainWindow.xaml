        <!-- T-110增分1(家老采配2026-07-22): 4分割DockingManager(ツールバー/左パレット/右パネル/
             出力パネル)を単一MainDockingManagerへ統合(隠密プラン§2.2案1トポロジ)。キャンバス
             (LadderCanvas)をLayoutDocumentPaneとして内包し、Manager全体でRootLayoutGrid行1(*行)を
             占める。旧4Manager個別のGridSplitter・Auto+Star列包み(T-099要件3の回避策、無限幅測定で
             マネージャ自身をコンテンツ要求幅まで縮める手法)・MainWorkAreaGrid等は全廃。AvalonDock
             標準の寸法管理(LayoutPanelControl.OnFixChildrenDockLengths、水平LayoutPanelの子孫に
             LayoutDocumentPaneが存在する場合は文書側をStar化し非文書側の固定DockWidthを尊重する
             仕様、v4.74.1一次ソース確認済み)に委ねることで、この回避策自体が不要になる
             (隠密プラン§2.2根拠)。 -->
        <Grid Grid.Row="1">
        <avalonDock:DockingManager x:Name="MainDockingManager"
                                   AnchorablePaneControlStyle="{StaticResource UnifiedAnchorablePaneControlStyle}">
            <avalonDock:DockingManager.Resources>
                <!-- T-104増分1 DoD(4)対策(家老采配2026-07-20、隠密設計): Tab前進がAutoHideサイド
                     領域(LayoutAnchorSideControl、4方向、通常時は空でも常にビジュアルツリーに
                     存在する)を巡回するのみでタブヘッダー間(基本機能⇔配置ツール)へ到達しない
                     問題(docs/ecad2-t104-canfloat-tabnav-root-cause-survey-onmitsu.md)への対処。
                     T-110增分1: 単一Manager化によりAutoHideサイド領域はウィンドウ全域に及ぶため、
                     本対処が全ペイン共通で有効になる(隠密プラン§3.5、望ましい方向)。 -->
                <Style TargetType="{x:Type avalonDock:LayoutAnchorSideControl}">
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="KeyboardNavigation.IsTabStop" Value="False"/>
                </Style>
