<Window x:Class="Ecad2.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ecad2.App"
        xmlns:views="clr-namespace:Ecad2.App.Views"
        xmlns:converters="clr-namespace:Ecad2.App.Converters"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        Title="ecad2" Height="800" Width="1280" WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        Closing="Window_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBool"/>
        <converters:DiagnosticSeverityToBrushConverter x:Key="SeverityToBrush"/>
        <converters:DiagnosticSeverityToTextConverter x:Key="SeverityToText"/>
        <converters:DeviceClassToTextConverter x:Key="DeviceClassToText"/>
        <converters:CircuitRefListToTextConverter x:Key="LocationsToText"/>

        <!-- ツールバーボタン共通スタイル: アイコン(Path)+F-key/ショートカット表示を縦積みにする
             (GX Works3実機調査T-012: マウス操作とキーボードショートカットの視覚的一体案内)。
             アイコンの絵柄は段階3では簡易プレースホルダ(Path Geometry)。本格意匠はT-013。 -->
        <Style x:Key="ToolBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <!-- T-047殿新注文その2(2026-07-09): 単純図形(縦線・横線等)のボタンはグレー化だけでは
                 活性/無効の判別が難しいとの殿目視所見。IsEnabled=false時にボタン全体を半透明化する
                 (殿選定=Windows標準的な無効表現・濃度差で単純図形でも判別可・実装最小)。基底
                 ToolBarButtonStyle1箇所への追加のみで、継承するPlacementToolBarButtonStyle
                 (F5〜F10・部品)・1段目(新規/開く等)双方に統一適用される。 -->
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ToolBarIconStyle" TargetType="Path">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Stroke" Value="Black"/>
            <Setter Property="StrokeThickness" Value="1.4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ToolBarKeyLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
        </Style>

        <!-- T-061(殿裁定(4)=ツールバーToggleButton+背景色変化、GuiEcad踏襲): ButtonとToggleButtonは
             ButtonBaseの兄弟クラスでBasedOnによる型混在継承ができないため、ToolBarButtonStyleと
             同じ寸法・無効化表現を独立定義し、IsChecked時の背景色変化のみ追加する。 -->
        <Style x:Key="TestModeToolBarButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{StaticResource TestModeActiveBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 2段目(配置系)専用スタイル(T-040、殿裁定=GX様式化の対象は2段目限定)。
             1段目(新規/開く/保存等)は上記ToolBarButtonStyle等のまま据え置く。 -->
        <Style x:Key="PlacementToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolBarButtonStyle}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
        </Style>
        <Style x:Key="PlacementToolBarIconStyle" TargetType="Path" BasedOn="{StaticResource ToolBarIconStyle}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <!-- 隠密指摘(縮小で線が密集し視認性低下)への手当て。サンプル(GX画像実測)の
                 線太さ:記号幅比は約5%、現状のToolBarIconStyle継承値1.4(18相当で7.8%)は
                 縮小後に過密な印象になるため、この段のみ細く上書きする。 -->
            <Setter Property="StrokeThickness" Value="1.0"/>
        </Style>
        <Style x:Key="PlacementToolBarKeyLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource ToolBarKeyLabelStyle}">
            <Setter Property="FontSize" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayoutGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- メニューバー -->
            <RowDefinition Height="Auto"/>  <!-- ツールバー(2段構成) -->
            <RowDefinition Height="*"/>     <!-- メイン作業域 -->
            <RowDefinition Height="Auto"/>  <!-- 下部出力パネル -->
            <RowDefinition Height="Auto"/>  <!-- ステータスバー -->
        </Grid.RowDefinitions>

        <!-- T-033増分2(隠密再レビュー改善事項): Menu/ToolBarTray/メイン作業域/OutputPanelAreaの
             IsEnabledバインドを本ラッパーGrid一箇所へ一元化(従来は4箇所個別バインド)。ルートGridの
             行0-3(メニュー〜出力パネル)をRowSpanでそのまま束ね、内部に同じ行構成(Auto/Auto/*/Auto)
             を持たせる。配置バー(ElementPlacementBar)・ステータスバーはこのラッパーの外に残し、
             常時有効のままとする(殿裁定=バー自身とステータスバーはグレーアウト対象外)。
             注意(隠密レビューCONFIRMED、T-033増分2位置バグ): 本ラッパーのRowSpanにより、ルートGrid
             の行0/1/3(Auto)はそれを単独専有する子要素を失い、WPF Gridの仕様上これらAuto行の実測
             サイズは実質0に潰れる。結果、ルートGrid自身の座標系(RootLayoutGrid基準)ではMainWorkAreaGrid
             の原点はラッパー経由で不変ではなくなる(ズレる)。PositionPlacementBarはこれを踏まえ、
             TranslatePointの変換先をRootLayoutGridへ揃えることで整合させている。
             T-059(出力パネル高さドラッグ調整、殿直接指示2026-07-11): 本ラッパー内部にGridSplitter用の
             行を1行追加(Auto/Auto/*/Auto/Auto、旧index3=OutputPanelAreaはindex4へ繰り下げ)。ラッパー
             自身のGrid.RowSpan=4・ルートGrid(RootLayoutGrid)の行構成(5行)は不変——本ラッパー内部専用の
             細分化のため、ラッパー外にあるStatusBarArea(Grid.Row="4"、RootLayoutGrid基準)の値には
             影響しない。 -->
        <Grid x:Name="MainContentArea" Grid.Row="0" Grid.RowSpan="4"
              IsEnabled="{Binding IsMainContentEnabled}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="160" MinHeight="80"/>
            </Grid.RowDefinitions>

        <!-- メニューバー: 最小限の項目構成(GX Works3同様のクラシックメニュー) -->
        <!-- T-083増分2: メニュー本体の配色をDynamicResource化(層C=UIクローム基盤)。 -->
        <Menu x:Name="MenuBarArea" Grid.Row="0"
              Background="{DynamicResource MenuBarBackgroundBrush}"
              Foreground="{DynamicResource MenuBarForegroundBrush}">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規(_N)" InputGestureText="Ctrl+N" Click="NewButton_Click"/>
                <MenuItem Header="開く(_O)" InputGestureText="Ctrl+O" Click="OpenButton_Click"/>
                <MenuItem Header="上書き保存(_S)" InputGestureText="Ctrl+S" Click="SaveButton_Click" IsEnabled="{Binding HasProject}"/>
                <MenuItem Header="名前を付けて保存(_A)..." Click="SaveAsMenuItem_Click" IsEnabled="{Binding HasProject}"/>
                <Separator/>
                <MenuItem Header="PDF出力(_P)" InputGestureText="Ctrl+P" Click="PdfExportMenuItem_Click" IsEnabled="{Binding HasProject}"/>
                <Separator/>
                <MenuItem Header="終了(_X)"/>
            </MenuItem>
            <MenuItem Header="編集(_E)">
                <MenuItem Header="元に戻す(_U)" InputGestureText="Ctrl+Z" Command="{Binding UndoCommand}"/>
                <MenuItem Header="やり直し(_R)" InputGestureText="Ctrl+Y" Command="{Binding RedoCommand}"/>
                <Separator/>
                <MenuItem Header="切り取り(_T)" InputGestureText="Ctrl+X"/>
                <MenuItem Header="コピー(_C)" InputGestureText="Ctrl+C"/>
                <MenuItem Header="貼り付け(_P)" InputGestureText="Ctrl+V"/>
                <Separator/>
                <MenuItem Header="削除(_D)" InputGestureText="Delete" Click="DeleteMenuItem_Click"
                          IsEnabled="{Binding CanEditDiagram}"/>
            </MenuItem>
            <MenuItem Header="図面(_D)">
                <MenuItem Header="ドキュメント情報(_I)" Click="DocumentInfoMenuItem_Click" IsEnabled="{Binding HasProject}"/>
                <!-- T-064(殿裁定): 挿入トリガー=メニューのみ(ツールバーボタン新設なし)。 -->
                <MenuItem Header="画像挿入(_M)..." Click="InsertImageMenuItem_Click" IsEnabled="{Binding CanEditDiagram}"/>
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="グリッド表示(_G)" IsCheckable="True" IsChecked="{Binding IsGridVisible, Mode=TwoWay}" InputGestureText="Ctrl+G"/>
                <!-- T-083 PoC(家老采配2026-07-15、殿指示済み配置): 作図キャンバス色のテーマ切替。
                     メニュー配置はここに確定済み、起動時既定・OSテーマ追従・永続化等はPoC後に殿確認。 -->
                <MenuItem Header="ダークモード(作図色)(_D)" IsCheckable="True" IsChecked="{Binding IsDarkMode, Mode=TwoWay}"/>
                <Separator/>
                <!-- T-058増分4(殿裁定=保存タイミング両方の1つ、明示コマンド): 現在のパネルレイアウト
                     (左パレット・出力パネル・右パネル)を既定として%AppData%配下へ保存する。
                     Ctrl+Alt+R(リセット)と対をなすキーバインド。 -->
                <MenuItem Header="現在のレイアウトを既定として保存(_L)" InputGestureText="Ctrl+Alt+S" Click="SaveDockingLayoutMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="ツール(_T)">
                <MenuItem Header="設計チェック実行(_D)" Command="{Binding OutputPanel.RunDrcCommand}"/>
                <MenuItem Header="テストモード(_M)" IsCheckable="True" IsChecked="{Binding IsTestMode, Mode=TwoWay}"
                          IsEnabled="{Binding HasProject}" InputGestureText="Ctrl+T"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- ツールバー: 2段構成(GX Works3同様。1段目=汎用操作、2段目=ラダー編集用途別コマンド)
             T-058増分5(殿裁定=2段目のみAvalonDock管轄内で可動化、1段目は現行ToolBarTray固定維持):
             既存Grid.Row="1"を内側Auto/Auto2行のラッパーGridへ差し替え、外側MainContentAreaの
             RowDefinitions・以降のGrid.Row参照(メイン作業域等)は無改修で済ませる(T-059の
             GridSplitter追加時と同型の「ラッパー内で行を増やす」手法、設計叩き台2節)。 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        <!-- T-083増分2: 1段目ツールバー本体の配色をDynamicResource化(層C=UIクローム基盤)。
             2段目(配置ツール)はAvalonDock管轄(層B、PlacementToolBarDockingManager)のため対象外。 -->
        <ToolBarTray x:Name="ToolBarArea" Grid.Row="0" IsLocked="True"
                     Background="{DynamicResource ToolBarBackgroundBrush}">
            <ToolBar Band="0" BandIndex="0" ToolBarTray.IsLocked="True"
                     Background="{DynamicResource ToolBarBackgroundBrush}"
                     Foreground="{DynamicResource ToolBarForegroundBrush}">
                <!-- T-095(殿裁定2026-07-15、方針転換): ラベル表示をショートカット表示から機能名表示へ
                     変更。ショートカットは既存ToolTip("機能名 (ショートカット)"形式)へマウスオーバー時
                     表示済みのためそのまま流用。機能名表記は簡潔化案(殿裁定=案2)を採用。 -->
                <Button Style="{StaticResource ToolBarButtonStyle}" ToolTip="新規作成 (Ctrl+N)"
                        AutomationProperties.Name="新規作成 (Ctrl+N)" Click="NewButton_Click">
                    <StackPanel>
                        <Path Style="{StaticResource ToolBarIconStyle}" Data="M2,2 L14,2 L14,16 L2,16 Z M2,2 L2,16 M14,2 L2,14"/>
                        <TextBlock Style="{StaticResource ToolBarKeyLabelStyle}" Text="新規"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" ToolTip="開く (Ctrl+O)"
                        AutomationProperties.Name="開く (Ctrl+O)" Click="OpenButton_Click">
                    <StackPanel>
                        <Path Style="{StaticResource ToolBarIconStyle}" Data="M1,4 L6,4 L8,6 L17,6 L17,15 L1,15 Z"/>
                        <TextBlock Style="{StaticResource ToolBarKeyLabelStyle}" Text="開く"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" ToolTip="上書き保存 (Ctrl+S)"
                        AutomationProperties.Name="上書き保存 (Ctrl+S)" Click="SaveButton_Click"
                        IsEnabled="{Binding HasProject}">
                    <StackPanel>
                        <Path Style="{StaticResource ToolBarIconStyle}" Data="M2,2 L14,2 L17,5 L17,17 L2,17 Z M5,2 L5,7 L13,7 L13,2 M5,17 L5,11 L13,11 L13,17"/>
                        <TextBlock Style="{StaticResource ToolBarKeyLabelStyle}" Text="保存"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button Style="{StaticResource ToolBarButtonStyle}" ToolTip="元に戻す (Ctrl+Z)"
                        AutomationProperties.Name="元に戻す (Ctrl+Z)" Command="{Binding UndoCommand}">
                    <StackPanel>
                        <Path Style="{StaticResource ToolBarIconStyle}" Data="M15,9 A6,6 0 1 1 9,3 M9,3 L9,7 M9,3 L13,4"/>
                        <TextBlock Style="{StaticResource ToolBarKeyLabelStyle}" Text="戻す"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" ToolTip="やり直し (Ctrl+Y)"
                        AutomationProperties.Name="やり直し (Ctrl+Y)" Command="{Binding RedoCommand}">
                    <StackPanel>
                        <Path Style="{StaticResource ToolBarIconStyle}" Data="M3,9 A6,6 0 1 0 9,3 M9,3 L9,7 M9,3 L5,4"/>
                        <TextBlock Style="{StaticResource ToolBarKeyLabelStyle}" Text="再実行"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button Style="{StaticResource ToolBarButtonStyle}" ToolTip="PDF出力 (Ctrl+P)"
                        AutomationProperties.Name="PDF出力 (Ctrl+P)" Click="PdfExportMenuItem_Click"
                        IsEnabled="{Binding HasProject}">
                    <StackPanel>
                        <Path Style="{StaticResource ToolBarIconStyle}" Data="M3,1 L11,1 L15,5 L15,17 L3,17 Z M11,1 L11,5 L15,5 M6,10 L12,10 M6,13 L10,13"/>
                        <TextBlock Style="{StaticResource ToolBarKeyLabelStyle}" Text="PDF出力"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button Style="{StaticResource ToolBarButtonStyle}" ToolTip="行を追加 (Ctrl+Shift+Up)"
                        AutomationProperties.Name="行を追加 (Ctrl+Shift+Up)"
                        Command="{Binding AddRowCommand}">
                    <StackPanel>
                        <Path Style="{StaticResource ToolBarIconStyle}" Data="M2,4 L11,4 M2,8 L11,8 M2,12 L11,12 M13,7 L13,13 M10,10 L16,10"/>
                        <TextBlock Style="{StaticResource ToolBarKeyLabelStyle}" Text="行追加"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" ToolTip="行を削除 (Ctrl+Shift+Down)"
                        AutomationProperties.Name="行を削除 (Ctrl+Shift+Down)"
                        Command="{Binding DeleteRowCommand}">
                    <StackPanel>
                        <Path Style="{StaticResource ToolBarIconStyle}" Data="M2,4 L11,4 M2,8 L11,8 M2,12 L11,12 M10,10 L16,10"/>
                        <TextBlock Style="{StaticResource ToolBarKeyLabelStyle}" Text="行削除"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <!-- T-061(殿裁定(2)(4)): テストモード切替。上位enum(AppMode)一元管理、ツールバー
                     ToggleButton+背景色変化(GuiEcad踏襲)。T-087でCtrl+Tショートカットが新設された
                     (MainWindow.xaml.cs、IsTestModeトグル)ため、他ボタンと同様ToolTip/
                     AutomationProperties.Nameへ併記する(表記漏れ修正、家老采配2026-07-15)。 -->
                <ToggleButton Style="{StaticResource TestModeToolBarButtonStyle}" ToolTip="テストモード (Ctrl+T)"
                              AutomationProperties.Name="テストモード (Ctrl+T)"
                              IsChecked="{Binding IsTestMode}"
                              IsEnabled="{Binding HasProject}">
                    <StackPanel>
                        <Path Style="{StaticResource ToolBarIconStyle}" Data="M4,3 L4,15 L14,9 Z"/>
                        <TextBlock Style="{StaticResource ToolBarKeyLabelStyle}" Text="テスト"/>
                    </StackPanel>
                </ToggleButton>
                <!-- T-061第五歩: 実時間タイマパネル(GuiEcad TimerPauseBtn踏襲)。テストモード中のみ
                     有効化する(タイマ命令を使わない回路では無害、殿裁定=段階導入5段階を今回スコープに含める)。 -->
                <ToggleButton x:Name="TimerPauseButton" Style="{StaticResource TestModeToolBarButtonStyle}"
                              ToolTip="タイマ一時停止" AutomationProperties.Name="タイマ一時停止"
                              Click="TimerPauseToggleButton_Click"
                              IsEnabled="{Binding IsTestMode}">
                    <StackPanel>
                        <Path Style="{StaticResource ToolBarIconStyle}" Data="M6,4 L6,14 M12,4 L12,14"/>
                        <TextBlock Style="{StaticResource ToolBarKeyLabelStyle}" Text="一時停止"/>
                    </StackPanel>
                </ToggleButton>
            </ToolBar>
        </ToolBarTray>
        <!-- T-058増分5(殿裁定=2段目のみAvalonDock管轄内で可動化): 独立DockingManager方式
             (増分1〜4と同型パターン踏襲)。ボタン群自体(Style/Command/ToolTip等)は無改修、
             配置場所のみ移動。 -->
        <avalonDock:DockingManager x:Name="PlacementToolBarDockingManager" Grid.Row="1">
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Horizontal">
                    <avalonDock:LayoutAnchorablePane>
                        <avalonDock:LayoutAnchorable Title="配置ツール" ContentId="PlacementToolBar" CanClose="False">
                            <ToolBar Band="0" BandIndex="0">
                <!-- ラダー専用コマンド。F5=AND(a接点)/F6=NAND(b接点)、Shift+F5=OR(ORa接点)/
                     Shift+F6=NOR(ORb接点)というキー体系(殿裁定、T-026段階4)。ボタンは「選択中セルへ
                     ダイアログ経由で配置」に統一(キーボードショートカットと同じTryPlaceElementを
                     Tag経由で呼ぶ、BuiltinPlaceButton_Click参照)。並び順・サイズ・キー凡例表記は
                     GX Works3様式へ統一(T-040、殿裁定=基本キーの直後にそのShift版を並べる)。
                     ツールチップ・AutomationProperties.Nameは正式名称(Shift+F5等)を維持し、
                     ボタン上のキー凡例のみ短縮表記(sF5等)にする(忍者のUIA検証互換への配慮)。
                     OR系(sF5/sF6)は接点記号の左右リード両端からそれぞれ上へ立ち上がる縦線を追加した
                     「└┤├┘」構図(殿の図示指定、並列回路の両端が上段配線へ繋がる意匠)、コイル(F7)は
                     真円、端子台(F8)は円を縦線が貫く「-Φ-」構図(いずれも殿の意匠指示、2026-07-06)。
                     線の太さはPlacementToolBarIconStyleでStrokeThickness=1.0に細くし、縮小後の
                     密集感を緩和(隠密指摘への手当て)。各グリフの境界ボックス(bounding box)は
                     Stretch=Uniformでのスケール不揃いを避けるため、対応する非OR/非差し替え版と
                     揃えている(隠密申し送り、F5/sF5=x2-16,y4-14・F6/sF6/F8=x2-16,y3-15)。 -->
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="選択ツール (Esc)"
                        AutomationProperties.Name="選択ツール (Esc)"
                        Click="SelectDefaultButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding HasProject}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M3,2 L3,16 L7,13 L9,17 L11,16 L9,12 L14,12 Z"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="Esc"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="a接点配置 (F5)"
                        AutomationProperties.Name="a接点配置 (F5)"
                        Tag="a接点" Click="BuiltinPlaceButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanEditDiagram}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M2,9 L6,9 M12,9 L16,9 M6,4 L6,14 M12,4 L12,14"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="F5"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="OR a接点配置 (Shift+F5)"
                        AutomationProperties.Name="OR a接点配置 (Shift+F5)"
                        Tag="OR:a接点" Click="BuiltinPlaceButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanEditDiagram}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M2,9 L6,9 M12,9 L16,9 M6,4 L6,14 M12,4 L12,14 M2,4 L2,9 M16,4 L16,9"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="sF5"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="b接点配置 (F6)"
                        AutomationProperties.Name="b接点配置 (F6)"
                        Tag="b接点" Click="BuiltinPlaceButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanEditDiagram}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M2,9 L6,9 M12,9 L16,9 M6,4 L6,14 M12,4 L12,14 M4,15 L14,3"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="F6"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="OR b接点配置 (Shift+F6)"
                        AutomationProperties.Name="OR b接点配置 (Shift+F6)"
                        Tag="OR:b接点" Click="BuiltinPlaceButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanEditDiagram}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M2,9 L6,9 M12,9 L16,9 M6,4 L6,14 M12,4 L12,14 M2,4 L2,9 M16,4 L16,9 M4,15 L14,3"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="sF6"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="コイル配置 (F7)"
                        AutomationProperties.Name="コイル配置 (F7)"
                        Tag="コイル" Click="BuiltinPlaceButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanEditDiagram}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M2,9 L4,9 M14,9 L16,9 M9,4 A5,5 0 1 1 8.999,4"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="F7"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="端子台配置 (F8)"
                        AutomationProperties.Name="端子台配置 (F8)"
                        Tag="端子台" Click="BuiltinPlaceButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanEditDiagram}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M2,9 L6,9 M12,9 L16,9 M9,6 A3,3 0 1 1 8.999,6 M9,3 L9,15"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="F8"/>
                    </StackPanel>
                </Button>
                <!-- T-047: 手動配線系(F9/Shift+F9/F10)のツールバーボタン。既存F5〜F8と同一の
                     ツールバー行に区切り線なしで連続配置(殿裁定2026-07-09、GX Works3のF5〜F10
                     連続配置様式に統一)。殿裁定=1機能1ボタン(最大5ボタン)・非対応シート種別は
                     グレーアウト。Shift+F9/F10はいずれもシート種別で挙動が切替わる1キーのため、
                     機能ごとに別ボタンへ分割し、IsEnabledをシート種別(IsMainCircuitSheet/
                     IsControlCircuitSheet)へ連動させる。意匠はT-040様式(StrokeThickness=1.0、
                     境界ボックス統一)。T-048(殿裁定2026-07-10、殿プレビュー承認済み)でグリフを確定=
                     シート種別で描き分ける: 主回路シート用は配置する物そのものを素朴に模す(自由線横線=
                     横線・自由線縦線=縦線・接続点=●)、制御シート用は殿提示サンプル意匠を基調とする
                     (縦分岐線=矢印形[sample/sF9_sample、上端の●を中心に左右へ枝を貫通させ分岐を表現+
                     縦線+下向き矢じり]・配線分断=はさみ形[sample/F10_sample])。 -->
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="自由線(横線)記入 (F9)"
                        AutomationProperties.Name="自由線(横線)記入 (F9)"
                        Click="FreeLineHorizontalButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanPlaceOnMainCircuit}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M2,9 L16,9"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="F9"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="自由線(縦線)記入 (Shift+F9)"
                        AutomationProperties.Name="自由線(縦線)記入 (Shift+F9)"
                        Click="FreeLineVerticalButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanPlaceOnMainCircuit}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M9,3 L9,15"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="sF9"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="縦分岐線記入 (Shift+F9)"
                        AutomationProperties.Name="縦分岐線記入 (Shift+F9)"
                        Click="VerticalConnectorButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanPlaceOnControlCircuit}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M9,3.3 m-1.3,0 a1.3,1.3 0 1 0 2.6,0 a1.3,1.3 0 1 0 -2.6,0 M4.5,3.3 L13.5,3.3 M9,4.6 L9,12 M5.5,9 L9,12.5 L12.5,9" Fill="Black"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="sF9"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="接続点記入 (F10)"
                        AutomationProperties.Name="接続点記入 (F10)"
                        Click="ConnectionDotButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanPlaceOnMainCircuit}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M9,9 m-3,0 a3,3 0 1 0 6,0 a3,3 0 1 0 -6,0" Fill="Black"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="F10"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="配線分断記入 (F10)"
                        AutomationProperties.Name="配線分断記入 (F10)"
                        Click="WireBreakButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanPlaceOnControlCircuit}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M5,3 L9,9 L12,13.5 M13,3 L9,9 L6,13.5 M6,12.2 A1.3,1.3 0 1 1 5.999,12.2 M12,12.2 A1.3,1.3 0 1 1 11.999,12.2"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="F10"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <!-- 家老采配(2026-07-15、表記漏れ修正): F11ショートカットが実在する
                     (MainWindow.xaml.cs、ActivateAndFocusPartSelection)にもかかわらずToolTip/
                     AutomationProperties.Nameに未併記だったため、他ボタンと同様の形式へ揃える。 -->
                <Button Style="{StaticResource PlacementToolBarButtonStyle}" ToolTip="自作パーツ (F11)"
                        AutomationProperties.Name="自作パーツ (F11)"
                        Click="OpenPartSelectionButton_Click"
                        PreviewKeyDown="ToolButtonPreviewKeyDown"
                        IsEnabled="{Binding CanEditDiagram}">
                    <StackPanel>
                        <Path Style="{StaticResource PlacementToolBarIconStyle}" Data="M3,3 L15,3 L15,15 L3,15 Z M9,6 L9,12 M6,9 L12,9"/>
                        <TextBlock Style="{StaticResource PlacementToolBarKeyLabelStyle}" Text="部品"/>
                    </StackPanel>
                </Button>
                            </ToolBar>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>
                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>
        </Grid>

        <!-- メイン作業域: 左パレット / 中央キャンバス / 右パネル -->
        <Grid x:Name="MainWorkAreaGrid" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPaletteColumn" Width="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="RightPanelColumn" Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- 左パレット: シートナビゲーション(T-026)。GuiEcadのナビツリー調査結果を踏襲し、
                 実質フラットリスト(1シート=1ノード、階層なし)とする。部品選択は右パネルへ移設予定
                 (T-026段階4、案B=状況依存切替)。
                 T-058増分1: AvalonDock導入。DockingManagerは当面この列(左パレット)のみを管理し、
                 増分2/3で出力パネル・右パネルを順次このDockingManagerへ追加していく土台とする
                 (キャンバス列のFindBarオーバーレイ座標系への影響を避けるため、案Aを一段絞った設計、
                 家老裁可済み)。既存のDockPanel中身(シート追加/削除/名前変更/設定ボタン・
                 D&D並び替え対応ListBox)はそのままLayoutAnchorableへ移植。 -->
            <avalonDock:DockingManager x:Name="LeftPaletteDockingManager" Grid.Column="0">
                <avalonDock:LayoutRoot>
                    <!-- LayoutRoot.RootPanelはLayoutPanel型必須(LayoutAnchorablePaneを直接子には
                         できない、実機確認で発覚したXamlParseException)。単一ペインでも
                         LayoutPanelで包む。 -->
                    <avalonDock:LayoutPanel Orientation="Horizontal">
                        <avalonDock:LayoutAnchorablePane>
                            <avalonDock:LayoutAnchorable Title="シート" ContentId="LeftPalette" CanClose="False">
                                <!-- 殿ご指摘(実機確認): AvalonDockのタブヘッダー自体がTitle="シート"を
                                     表示するため、旧実装の手動タイトルTextBlockは二重表示になっていた。削除。 -->
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                                        <Button x:Name="AddSheetButton" Content="＋" Width="28" ToolTip="シート追加"
                                                Click="AddSheetButton_Click"/>
                                        <Button x:Name="DeleteSheetButton" Content="－" Width="28" Margin="4,0,0,0" ToolTip="シート削除"
                                                Command="{Binding SheetNavigation.DeleteCommand}"/>
                                        <Button x:Name="RenameSheetButton" Content="名前変更" Margin="4,0,0,0" ToolTip="シート名変更"
                                                Click="RenameSheetButton_Click"/>
                                        <Button x:Name="SheetSettingsButton" Content="設定" Margin="4,0,0,0"
                                                ToolTip="シート設定(行数・母線名)" Click="SheetSettingsButton_Click"/>
                                    </StackPanel>
                                    <!-- T-082: ドラッグ&ドロップ並び替え(殿裁定「案A」=標準フィードバック)。
                                         AllowDrop+Preview系マウスイベント+DragOver/Dropはコードビハインドで処理する
                                         (WPFのListBoxに標準並び替え機能は無く明示実装、Explore調査で確認済み)。 -->
                                    <ListBox x:Name="SheetNavList" ItemsSource="{Binding SheetNavigation.Sheets}"
                                             SelectedItem="{Binding SheetNavigation.SelectedSheet}"
                                             DisplayMemberPath="Name" BorderThickness="0" AllowDrop="True"
                                             PreviewMouseLeftButtonDown="SheetNavList_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="SheetNavList_PreviewMouseMove"
                                             DragOver="SheetNavList_DragOver"
                                             DragLeave="SheetNavList_DragLeave"
                                             Drop="SheetNavList_Drop"/>
                                </DockPanel>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                    </avalonDock:LayoutPanel>
                </avalonDock:LayoutRoot>
            </avalonDock:DockingManager>

            <!-- IsTabStop=Falseはタブオーダーからの除外のみ(懸念4の迷い込み先解消、T-021設計集約
                 プラン根拠4)。Focusable自体は既定のtrueのまま残し矢印キーでのリサイズは温存する。 -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" KeyboardNavigation.IsTabStop="False"/>

            <!-- 中央キャンバス: 図面描画。空状態(濃紺)⇔作業領域(白)の状態依存配色はHasProject
                 バインディング経由で切替わる(T-020、ScrollViewer.Style参照)。Ctrl+マウスホイールで
                 拡大縮小(ScaleTransform)。キーボードでのズーム操作は段階8(キーボード規約の全体配線)
                 でまとめて対応する。 -->
            <ScrollViewer x:Name="CanvasArea" Grid.Column="2"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="CanvasArea_PreviewMouseWheel"
                          FocusManager.IsFocusScope="True">
                <ScrollViewer.Style>
                    <!-- 空状態(濃紺)⇔作業領域(白)の状態依存配色(T-020、殿裁定=GX Works3踏襲)。
                         HasProject=falseの間(ドキュメント未作成)はEmptyStateBackgroundBrushに切替わる。
                         起動直後はDocument.Sheets=0(HasProject=false)で開始し濃紺スタート(殿裁定
                         2026-07-05)、新規/開くで白の作業領域へ遷移する(MainWindowViewModel.
                         HasProject/NotifyHasProjectChanged参照)。 -->
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Background" Value="{DynamicResource WorkAreaBackgroundBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasProject}" Value="False">
                                <Setter Property="Background" Value="{DynamicResource EmptyStateBackgroundBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <views:LadderCanvas x:Name="LadderCanvasHost"
                                    PreviewMouseLeftButtonDown="LadderCanvasHost_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="LadderCanvasHost_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="LadderCanvasHost_PreviewMouseLeftButtonUp"
                                    PreviewMouseRightButtonDown="LadderCanvasHost_PreviewMouseRightButtonDown"
                                    LostMouseCapture="LadderCanvasHost_LostMouseCapture">
                    <views:LadderCanvas.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding CanvasScale}" ScaleY="{Binding CanvasScale}"/>
                    </views:LadderCanvas.LayoutTransform>
                </views:LadderCanvas>
            </ScrollViewer>

            <!-- T-070(殿裁定(1)=上部バー、GuiEcad踏襲): 検索・置換オーバーレイ。Ctrl-Fでトグル表示。
                 作図エリア(Grid.Column="2")の上部に重ねる、ElementPlacementBarと同型の同一Window内
                 オーバーレイ設計。検索対象は機器名完全一致のみ(殿裁定(2))。 -->
            <Border x:Name="FindBar" Grid.Column="2" Background="White" BorderBrush="Gray"
                    BorderThickness="1" Padding="6" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                    Visibility="{Binding Find.IsVisible, Converter={StaticResource BoolToVisibility}}"
                    Panel.ZIndex="100">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="検索:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="FindQueryBox" Width="140" VerticalAlignment="Center" Margin="0,0,4,0"
                             AutomationProperties.Name="検索"
                             Text="{Binding Find.Query, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="FindQueryBox_PreviewKeyDown"/>
                    <TextBlock Text="{Binding Find.StatusText}" VerticalAlignment="Center" Width="60" Margin="0,0,4,0"/>
                    <Button Content="前" Width="32" VerticalAlignment="Center" Margin="0,0,2,0"
                            AutomationProperties.Name="前へ" Command="{Binding Find.PrevCommand}"/>
                    <Button Content="次" Width="32" VerticalAlignment="Center" Margin="0,0,8,0"
                            AutomationProperties.Name="次へ" Command="{Binding Find.NextCommand}"/>
                    <Separator/>
                    <TextBlock Text="置換後:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox x:Name="FindReplaceBox" Width="140" VerticalAlignment="Center" Margin="0,0,4,0"
                             AutomationProperties.Name="置換後"
                             Text="{Binding Find.ReplaceWith, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="置換" Width="48" VerticalAlignment="Center" Margin="0,0,4,0"
                            AutomationProperties.Name="置換" Command="{Binding Find.ReplaceOneCommand}"/>
                    <Button Content="全置換" Width="56" VerticalAlignment="Center" Margin="0,0,8,0"
                            AutomationProperties.Name="全置換" Command="{Binding Find.ReplaceAllCommand}"/>
                    <Button Content="閉じる" Width="56" VerticalAlignment="Center"
                            AutomationProperties.Name="検索バーを閉じる" Click="FindCloseButton_Click"/>
                </StackPanel>
            </Border>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" KeyboardNavigation.IsTabStop="False"/>

            <!-- 右パネル: 機器表/プロパティ。design-brief 3節#7(タブ排他式・固定幅の反省)を踏まえ、
                 上下2分割で常時同時参照可能にする(タブ切替不要)。
                 T-058増分3: AvalonDock導入。左パレット・出力パネルと同様、独立したDockingManagerとして
                 この列(右パネル)のみを管理する(案C踏襲、家老裁可済み)。上下分割はLayoutPanel
                 (Orientation="Vertical")一つで実現(内蔵リサイザーに置き換わるため旧GridSplitterは削除)。
                 下段(プロパティ⇔部品選択)のタイトルはAvalonDockのオフツリー構造ゆえBindingが機能せず
                 (docs-notes/handover-next-session.md§3)、MainWindow.xaml.csでIsPartSelectionVisible変更を
                 購読しTitleを直接更新する方式(UpdateRightPanelBottomTitle参照、増分2のUpdateOutputPanelTitle
                 と同型)。手動タイトルTextBlockはAvalonDockタブヘッダーとの二重表示を避けるため削除
                 (増分1/2の教訓)。 -->
            <avalonDock:DockingManager x:Name="RightPanelDockingManager" Grid.Column="4">
                <avalonDock:LayoutRoot>
                    <avalonDock:LayoutPanel Orientation="Vertical">
                        <!-- T-058増分3範囲内欠陥修正(家老采配、忍者実機確認で実害確定): AvalonDock既定の
                             DockMinHeight(25px、隠密reflection実測)ではDataGridが完全に不可視(BoundingRectangle
                             =Empty)になるまで境界ドラッグで縮小可能だった。旧Grid実装時代のMinHeight="80"
                             (MainContentArea.RowDefinitions、既存T-059出力パネル領域と同値)を踏襲し明示指定する。 -->
                        <avalonDock:LayoutAnchorablePane DockMinHeight="80">
                            <avalonDock:LayoutAnchorable Title="機器表" ContentId="DeviceTable" CanClose="False">
                                <DataGrid x:Name="DeviceTableGrid" ItemsSource="{Binding DeviceTable.Devices}" AutoGenerateColumns="False"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" CellEditEnding="DeviceTableGrid_CellEditEnding"
                                          CanUserAddRows="False" CanUserDeleteRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="機器名" Binding="{Binding Name}" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="種別" Binding="{Binding Class, Converter={StaticResource DeviceClassToText}}" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="型式" Binding="{Binding Model}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                        <avalonDock:LayoutAnchorablePane DockMinHeight="80">
                            <!-- 下段: プロパティ ⇔ 部品選択の状況依存切替(T-026段階4-7、案B=GX Works3式)。
                                 Tool.Mode==PlaceElementの間は部品選択(自作パーツ含む全SelectionEntries、
                                 サムネイル付きラッパー。T-015)を表示し、それ以外はプロパティを表示する。
                                 プロパティ側はさらにHasSelectedElementで「要素を選択してください」
                                 プレースホルダと選択中要素の詳細表示を切替える(T-017)。Title初期値="プロパティ"
                                 (既定表示、UpdateRightPanelBottomTitleが以後の状況変化を追従)。 -->
                            <avalonDock:LayoutAnchorable Title="プロパティ" ContentId="RightPanelBottom" CanClose="False">
                                <Grid>
                                    <DockPanel Visibility="{Binding IsPartSelectionVisible, Converter={StaticResource InverseBoolToVisibility}}">
                                        <TextBlock Text="要素を選択してください" Foreground="Gray" Margin="4" TextWrapping="Wrap"
                                                   Visibility="{Binding HasNoPropertySelection, Converter={StaticResource BoolToVisibility}}"/>
                                        <StackPanel Margin="4" Visibility="{Binding HasSelectedElement, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding SelectedElementKindDisplay, StringFormat='種別: {0}'}"/>
                                            <TextBlock Text="デバイス名:" Margin="0,8,0,2"/>
                                            <TextBox x:Name="DeviceNameBox" Text="{Binding SelectedElementDeviceName, UpdateSourceTrigger=Explicit}"
                                                     IsEnabled="{Binding CanEditDiagram}"
                                                     LostKeyboardFocus="DeviceNameBox_LostKeyboardFocus" PreviewKeyDown="DeviceNameBox_PreviewKeyDown"/>
                                            <!-- T-086: セレクトSW限定のノッチ位置入力欄。DeviceNameBoxと同型
                                                 (UpdateSourceTrigger=Explicit+LostKeyboardFocus/Enterで確定)。 -->
                                            <StackPanel Visibility="{Binding IsSelectedElementSelectSwitch, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="ノッチ位置:" Margin="0,8,0,2"/>
                                                <TextBox x:Name="NotchPositionBox" Text="{Binding SelectedElementNotchPosition, UpdateSourceTrigger=Explicit}"
                                                         IsEnabled="{Binding CanEditDiagram}"
                                                         LostKeyboardFocus="NotchPositionBox_LostKeyboardFocus" PreviewKeyDown="NotchPositionBox_PreviewKeyDown"/>
                                            </StackPanel>
                                            <!-- T-085: 表示灯(Lamp)限定の色記号入力欄(殿裁定2026-07-13、丸内に表示するフリーテキスト
                                                 記号であり実際の表示色ではない)。DeviceNameBoxと同型のExplicit確定に加え、クリア
                                                 ボタン(×)を新設する。 -->
                                            <StackPanel Visibility="{Binding IsSelectedElementLamp, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="ランプ色（中央表示）:" Margin="0,8,0,2"/>
                                                <DockPanel LastChildFill="True">
                                                    <Button DockPanel.Dock="Right" Content="×" Width="24" Margin="4,0,0,0"
                                                            IsEnabled="{Binding CanEditDiagram}"
                                                            Click="LampColorClearButton_Click"
                                                            AutomationProperties.Name="ランプ色クリア"/>
                                                    <TextBox x:Name="LampColorBox" Text="{Binding SelectedElementLampColor, UpdateSourceTrigger=Explicit}"
                                                             MaxLength="2"
                                                             IsEnabled="{Binding CanEditDiagram}"
                                                             LostKeyboardFocus="LampColorBox_LostKeyboardFocus" PreviewKeyDown="LampColorBox_PreviewKeyDown"/>
                                                </DockPanel>
                                            </StackPanel>
                                            <!-- T-096: タイマ接点(限時/瞬時NO/NC計4種)限定の設定時間入力欄(殿裁定=GuiEcad完全踏襲、
                                                 NumberBox代替のTextBox+Sliderの2点セット・双方向同期)。TextBoxはDeviceNameBoxと同型の
                                                 Explicit確定、SliderはGuiEcad仕様どおり通常のTwoWayバインディング(ドラッグ中
                                                 リアルタイム反映)。 -->
                                            <StackPanel Visibility="{Binding IsSelectedElementTimerRelated, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="設定時間(秒):" Margin="0,8,0,2"/>
                                                <TextBox x:Name="SetpointBox" Text="{Binding SelectedElementSetpoint, UpdateSourceTrigger=Explicit}"
                                                         IsEnabled="{Binding CanEditDiagram}"
                                                         LostKeyboardFocus="SetpointBox_LostKeyboardFocus" PreviewKeyDown="SetpointBox_PreviewKeyDown"/>
                                                <Slider Minimum="0" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True"
                                                        Value="{Binding SelectedElementSetpointSliderValue, Mode=TwoWay}"
                                                        IsEnabled="{Binding CanEditDiagram}"
                                                        AutomationProperties.Name="設定時間クイック設定(0～10秒)"/>
                                            </StackPanel>
                                            <!-- T-097: ラベル高さオフセット(LabelDy)入力欄。全要素種別共通(種別限定なし、
                                                 ラベル密集時の重なり回避用個別微調整)。殿裁定=種別既定の表示位置を0とした
                                                 相対オフセット方式。DeviceNameBox等と同型のExplicit確定。 -->
                                            <StackPanel>
                                                <TextBlock Text="ラベル高さ調整(mm、既定位置=0):" Margin="0,8,0,2"/>
                                                <TextBox x:Name="LabelDyBox" Text="{Binding SelectedElementLabelDy, UpdateSourceTrigger=Explicit}"
                                                         IsEnabled="{Binding CanEditDiagram}"
                                                         LostKeyboardFocus="LabelDyBox_LostKeyboardFocus" PreviewKeyDown="LabelDyBox_PreviewKeyDown"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- T-064: 画像選択時のプロパティ表示。リサイズはドラッグハンドル方式(殿裁定)の
                                             ため数値入力は設けず、ファイルパス表示+トレーストグルのみとする。 -->
                                        <StackPanel Margin="4" Visibility="{Binding HasSelectedImage, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="画像" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SelectedImage.FilePath}" TextWrapping="Wrap" Margin="0,4,0,4" Foreground="Gray"/>
                                            <CheckBox Content="トレース用下絵(印刷に含めない)" IsChecked="{Binding SelectedImageIsTracingOnly, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <ListBox x:Name="PartSelectionList" ItemsSource="{Binding PartPalette.SelectionEntries}" BorderThickness="0"
                                             Visibility="{Binding IsPartSelectionVisible, Converter={StaticResource BoolToVisibility}}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="2">
                                                    <Image Source="{Binding Thumbnail}" Width="24" Height="24" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding Category}" Foreground="Gray" FontSize="10" Width="40" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="PartSelectionItem_Clicked"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Grid>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                    </avalonDock:LayoutPanel>
                </avalonDock:LayoutRoot>
            </avalonDock:DockingManager>
        </Grid>

        <!-- T-059(殿直接指示2026-07-11): メイン作業域⇔出力パネルの高さをドラッグ調整可能にする
             (RightPanelArea、456行の上下分割と同一パターン)。 -->
        <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch" KeyboardNavigation.IsTabStop="False"/>

        <!-- 下部出力パネル: DesignRuleCheck(T-007移植済み)の結果を構造化DataGridで表示する(T-018、
             殿裁定=構造化DataGrid＋重大度色分け)。実行はツール(_T)メニュー「設計チェック実行」から。
             行選択でGuiEcadのCenterViewOnRow相当のジャンプ(該当シート・セルへ選択移動)を行う
             (OutputPanelViewModel.SelectedDiagnostic参照)。高さはGridSplitterでドラッグ調整可能
             (T-059、既定160・MinHeight=80はMainContentArea.RowDefinitions側で指定)。
             T-058増分2: AvalonDock化。左パレット用DockingManagerとは独立した2つ目のインスタンスとして
             この位置(MainContentArea.Row="4")のみを管理する(案C、家老裁可済み)。既存のT-059
             GridSplitter(直前のGrid.Row="3")はDockingManager外側の境界リサイズ用としてそのまま維持する
             (DockingManager自身が持つのは内部ペイン間のリサイザーのみ)。 -->
        <avalonDock:DockingManager x:Name="OutputPanelDockingManager" Grid.Row="4">
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Horizontal">
                    <avalonDock:LayoutAnchorablePane>
                        <!-- 殿ご指摘(実機確認)による2周目修正: AvalonDockのタブヘッダー自体がTitleを表示する
                             ため、旧実装の手動タイトルTextBlock(出力/検索結果切替)は二重表示になっていた
                             (1周目で解消)。しかしTitleへの{Binding Find.IsVisible}は忍者実機確認で完全に
                             空白になる新たな不具合を招いた——原因はLayoutAnchorable(LayoutContent→
                             LayoutElement:DependencyObject)がFrameworkElementではなくWPFのDataContext
                             継承(Visual/Logical Tree経由)の対象外のため(GitHub一次ソース確認済み、
                             忍者の推測通り)。BindingではなくMainWindow.xaml.csでFind.PropertyChangedを
                             購読しTitleを直接更新する方式に切替える(UpdateOutputPanelTitle参照)。 -->
                        <avalonDock:LayoutAnchorable Title="出力" ContentId="OutputPanel" CanClose="False">
                            <DockPanel>
                                <!-- T-070隠密レビュー指摘A-9: 2つのDataGridをDockPanelへ直接並べると、Fill対象(Star列展開)を
                                     受けられるのは最後の子のみというDockPanel仕様上、FindResultsGridがDock.Left扱いとなり
                                     該当箇所列(Width="*")が正しく展開されず左寄せの狭い帯になっていた。Gridでラップし両方を
                                     重ねてVisibilityで切替える(上のTextBlock 2枚と同型のパターン)ことで、Gridの方が
                                     DockPanelのFill対象になり両DataGridとも正しくStar列展開を受けられるようにする。 -->
                                <Grid>
                                    <DataGrid x:Name="FindResultsGrid" ItemsSource="{Binding Find.Matches}"
                                              Visibility="{Binding Find.IsVisible, Converter={StaticResource BoolToVisibility}}"
                                              AutoGenerateColumns="False" IsReadOnly="True"
                                              HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="FindResultsGridRow_Clicked"/>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="シート" Binding="{Binding SheetName}" Width="100"/>
                                            <DataGridTextColumn Header="機器名" Binding="{Binding DeviceName}" Width="100"/>
                                            <DataGridTextColumn Header="該当箇所" Binding="{Binding Location}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <DataGrid x:Name="OutputGrid" ItemsSource="{Binding OutputPanel.Diagnostics}"
                                              SelectedItem="{Binding OutputPanel.SelectedDiagnostic}"
                                              Visibility="{Binding Find.IsVisible, Converter={StaticResource InverseBoolToVisibility}}"
                                              AutoGenerateColumns="False" IsReadOnly="True"
                                              HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                        <DataGrid.RowStyle>
                                            <!-- 同一行の再クリックでもジャンプを確実に実行する(T-018忍者実機検証で発見、
                                                 T-016のPartSelectionItem_Clickedと同種のWPF既知の罠への対処)。 -->
                                            <Style TargetType="DataGridRow">
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OutputGridRow_Clicked"/>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="重大度" Binding="{Binding Severity, Converter={StaticResource SeverityToText}}"
                                                                Width="60">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{Binding Severity, Converter={StaticResource SeverityToBrush}}"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="コード" Binding="{Binding Code}" Width="110"/>
                                            <DataGridTextColumn Header="機器名" Binding="{Binding DeviceName}" Width="80"/>
                                            <DataGridTextColumn Header="メッセージ" Binding="{Binding Message}" Width="*"/>
                                            <DataGridTextColumn Header="該当箇所" Binding="{Binding Locations, Converter={StaticResource LocationsToText}}"
                                                                Width="140"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </DockPanel>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>
                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>
        </Grid>

        <!-- ステータスバー: design-brief 4節#6「モード可視化の多重化」。現在の配置ツールモードと
             ズーム率を表示する最小実装。GX Works3同等の高情報密度(機種名/局番/ステップ数等)は
             本実装向け機能に依存するため将来タスク。 -->
        <StatusBar x:Name="StatusBarArea" Grid.Row="4">
            <!-- T-061(調査書DoD(3)7項目目「ステータスバー連携」): モード表示。Tool.Modeと同じ
                 enumそのまま表示パターン(日本語化はT-053同様の別タスク扱い、既存流儀踏襲)。 -->
            <StatusBarItem>
                <TextBlock Text="{Binding Mode, StringFormat='モード: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding Tool.Mode, StringFormat='ツール: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedCellDisplay, StringFormat='選択セル: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <!-- T-041増分7(殿裁定P-033=案2): 線分プリミティブ(VerticalConnector/FreeLine)選択中のみ
                 Tabで切替える操作対象端点(始点/終点)を表示する。 -->
            <StatusBarItem Visibility="{Binding HasSelectedLinePrimitive, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding SelectedEndpointDisplay, StringFormat='操作対象: {0}'}"/>
            </StatusBarItem>
            <Separator Visibility="{Binding HasSelectedLinePrimitive, Converter={StaticResource BoolToVisibility}}"/>
            <StatusBarItem>
                <TextBlock Text="{Binding CanvasScale, StringFormat='ズーム: {0:P0}'}"/>
            </StatusBarItem>
            <Separator/>
            <!-- T-080殿直命(仕上げ確認): 行コメントエディタ表示中の操作案内。IsRungCommentEditorVisible
                 連動(HasSelectedLinePrimitiveと同型のVisibilityパターン)。閉じれば非表示に戻り、
                 元の表示(StatusMessage等)を上書きしない。 -->
            <StatusBarItem Visibility="{Binding IsRungCommentEditorVisible, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="行コメント編集中: Enterで確定・Escで取消"/>
            </StatusBarItem>
            <Separator Visibility="{Binding IsRungCommentEditorVisible, Converter={StaticResource BoolToVisibility}}"/>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="DarkRed"/>
            </StatusBarItem>
        </StatusBar>

        <!-- T-033増分1/2/3: 配置後入力の非モーダル浮動インラインバー(同一Window内オーバーレイ、
             隠密所見によりPopup不採用。docs/ecad2-t033-ui-automation-impact-survey-onmitsu.md参照)。
             増分2(殿注文、構想図docs/images/t033-gxworks3-inline-input-reference.png踏襲):
             (1)選択セル直下への表示位置(コードビハインドのPositionPlacementBar算出、
             HorizontalAlignment/VerticalAlignment=Left/Top+Marginで制御) (2)小型横長化+
             接点選択/機器名入力の横並び (3)画面端クランプ。表示状態はIsPlacementBarVisible
             (ViewModel単一の真実源、隠密レビュー指摘)へバインドし、MainContentAreaのIsEnabledと
             連動させることで、キーボード(Window_PreviewKeyDown冒頭の早期リターン)・マウスの
             両経路を同時に無効化する(殿裁定=現行モーダル同等の使用感)。構想図左端[小アイコン類]は
             機能未定(殿裁定2026-07-07=見た目だけ構想図と一致させる、押下無反応のプレースホルダ)。
             末尾[拡張表示]は増分3で配置のみ実装(詳細画面はT-028で別途実装予定、本増分では押下無反応)。 -->
        <Border x:Name="ElementPlacementBar" Grid.Row="2" Background="White" BorderBrush="Gray"
                BorderThickness="1" Padding="6" HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="{Binding IsPlacementBarVisible, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="100">
            <StackPanel Orientation="Horizontal">
                <!-- 小アイコン類(殿裁定2026-07-07): 構想図の視覚のみ踏襲するプレースホルダ。
                     機能未定のため押下無反応(Clickハンドラ未配線、増分3の拡張表示ボタンと同種の扱い)。
                     グリフ自体に意味は無く、将来タスクで機能定義される想定。恒久的に非機能のため、
                     GridSplitterと同じくKeyboardNavigation.IsTabStop="False"でタブオーダーから除外する
                     (隠密レビューCONFIRMED、押しても何も起きないボタンへのTab迷い込み防止)。 -->
                <Button Width="24" Height="24" Padding="2" VerticalAlignment="Center" Margin="0,0,4,0"
                        AutomationProperties.Name="(未定アイコン1)" KeyboardNavigation.IsTabStop="False">
                    <Path Style="{StaticResource PlacementToolBarIconStyle}"
                          Data="M3,3 L13,3 L13,9 L3,9 Z M5,3 L5,1 L11,1 L11,3 M6,9 L6,12 L10,12 L10,9"/>
                </Button>
                <Button Width="24" Height="24" Padding="2" VerticalAlignment="Center" Margin="0,0,8,0"
                        AutomationProperties.Name="(未定アイコン2)" KeyboardNavigation.IsTabStop="False">
                    <Path Style="{StaticResource PlacementToolBarIconStyle}"
                          Data="M2,3 L12,3 L12,9 L7,9 L4,13 L4,9 L2,9 Z"/>
                </Button>
                <!-- 種別選択(T-033増分4/5、殿注文=省スペース化+表示どおりの動作): 文字表記から
                     シンボルのみ表示へ変更。項目は部品選択リストと同じ全種(ORa/ORb含む、
                     PartPaletteViewModel.SelectionEntries、並び順もリストと同一)。アイコンは
                     PartSelectionEntryViewModel.Thumbnail(PartThumbnailRenderer生成のImageSource)を
                     そのまま流用する(T-071、殿裁定=方式B。実体記号描画への統一のため専用手作り
                     Geometryは廃止、選択中部品の大サムネイル欄と生成元が同一になり新規部品追加時も
                     自動対応)。ToolTip・AutomationProperties.Nameは正式名称(DisplayName、IsOr時は
                     「ORa接点」等)を維持し(忍者のUIA検証互換)、コントロール自体は選択中の部品名を
                     動的反映、ドロップダウン各項目はItemContainerStyleでその部品自身の名称を持つ。
                     ドロップダウンで選んだ項目そのものがOR属性も決める(PlacementOkButton_Click参照、
                     T-037の暗黙保持ルールはT-033増分5で廃止)。 -->
                <ComboBox x:Name="PlacementPartComboBox" Width="40"
                          VerticalAlignment="Center" Margin="0,0,8,0"
                          ToolTip="{Binding SelectedItem.DisplayName, RelativeSource={RelativeSource Self}, FallbackValue=種別選択}"
                          AutomationProperties.Name="{Binding SelectedItem.DisplayName, RelativeSource={RelativeSource Self}, FallbackValue=種別選択}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Thumbnail}" Width="14" Height="14" Stretch="Uniform"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="ToolTip" Value="{Binding DisplayName}"/>
                            <Setter Property="AutomationProperties.Name" Value="{Binding DisplayName}"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <!-- 選択中部品のサムネイル・名前表示エリア(T-054、殿裁定=P-023案A)。リスト側
                     (PartSelectionList)にSelectedItemバインドを新設せず、配置バー内で完結させる
                     (案B相当は不採用)。PlacementPartComboBox.SelectedItemをElementName経由で
                     そのまま参照するため、初期選択(TryPlaceElement)・ドロップダウンでの選び直し
                     いずれにも自動追従し、専用の同期コード(SelectionChangedハンドラ等)は不要。 -->
                <Image x:Name="SelectedPartThumbnail"
                       Source="{Binding SelectedItem.Thumbnail, ElementName=PlacementPartComboBox}"
                       Width="24" Height="24" Margin="0,0,4,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="SelectedPartNameText"
                           Text="{Binding SelectedItem.DisplayName, ElementName=PlacementPartComboBox}"
                           MinWidth="60" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="PlacementDeviceNameBox" Width="220" VerticalAlignment="Center" Margin="0,0,8,0"
                         AutomationProperties.Name="デバイス名"/>
                <Button Content="OK" Width="60" VerticalAlignment="Center" IsDefault="True" Click="PlacementOkButton_Click" Margin="0,0,4,0"/>
                <Button Content="キャンセル" Width="76" VerticalAlignment="Center" IsCancel="True" Click="PlacementCancelButton_Click" Margin="0,0,8,0"/>
                <!-- 拡張表示ボタン(T-033増分3): 構想図末尾の[拡張表示]の配置のみ。詳細画面はT-028で
                     別途実装予定のため、本増分ではClickハンドラ未配線・押下無反応(左端の小アイコン類と
                     同様の暫定状態)。
                     Tab順(殿裁定、隠密実機検証後の修正): 当初は侍技術裁量でTabオーダーに含めていたが、
                     隠密実機検証で「本ボタンにフォーカス中にEnterを押してもOK確定が発火しない」実害が
                     確認されたため、安全側としてKeyboardNavigation.IsTabStop="False"で除外する。T-028で
                     詳細画面機能を実装する際にTabオーダーへ復帰させること。 -->
                <Button Content="拡張表示" VerticalAlignment="Center" AutomationProperties.Name="拡張表示"
                        KeyboardNavigation.IsTabStop="False"/>
            </StackPanel>
        </Border>

        <!-- T-080: 行コメント編集用インラインTextBoxオーバーレイ(ElementPlacementBarと同型の
             同一Window内オーバーレイ設計、位置決めもPositionPlacementBarと同型のTranslatePoint方式を
             流用)。GuiEcad原本踏襲: 右母線右側ダブルクリックで開き(F2キーの等価経路あり、殿裁定・
             往復1周目追加I)、Enter/Tab確定・Esc取消・フォーカスロストは確定扱い。文字数上限20は殿裁定。
             表示状態はIsRungCommentEditorVisible(ViewModel単一の真実源、往復1周目指摘F)へバインドし、
             配置バーと同様にMainContentAreaのIsEnabled(IsMainContentEnabled)と連動させることで、
             編集中のキーボード(Window_PreviewKeyDown冒頭ガード)・マウスの両経路を同時に無効化する。 -->
        <Border x:Name="RungCommentEditor" Grid.Row="2" Background="White" BorderBrush="Gray"
                BorderThickness="1" Padding="2" HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="{Binding IsRungCommentEditorVisible, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="100">
            <TextBox x:Name="RungCommentBox" Width="140" MaxLength="20"
                     AutomationProperties.Name="行コメント"
                     PreviewKeyDown="RungCommentBox_PreviewKeyDown"
                     LostKeyboardFocus="RungCommentBox_LostKeyboardFocus"/>
        </Border>
    </Grid>
</Window>
