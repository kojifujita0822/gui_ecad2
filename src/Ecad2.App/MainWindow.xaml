<Window x:Class="Ecad2.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ecad2.App"
        xmlns:views="clr-namespace:Ecad2.App.Views"
        xmlns:converters="clr-namespace:Ecad2.App.Converters"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:vs2013Themes="clr-namespace:AvalonDock.Themes.VS2013.Themes;assembly=AvalonDock.Themes.VS2013"
        mc:Ignorable="d"
        Title="ecad2" Height="800" Width="1280" WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        Closing="Window_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBool"/>
        <converters:DiagnosticSeverityToBrushConverter x:Key="SeverityToBrush"/>
        <converters:DiagnosticSeverityToTextConverter x:Key="SeverityToText"/>
        <converters:DeviceClassToTextConverter x:Key="DeviceClassToText"/>
        <converters:CircuitRefListToTextConverter x:Key="LocationsToText"/>

        <!-- ツールバーボタン共通スタイル: アイコン(Path)+F-key/ショートカット表示を縦積みにする
             (GX Works3実機調査T-012: マウス操作とキーボードショートカットの視覚的一体案内)。
             アイコンの絵柄は段階3では簡易プレースホルダ(Path Geometry)。本格意匠はT-013。 -->
        <!-- T-089(家老采配2026-07-17): 押下フィードバック叩き台をアプリ全体へ波及させるため
             App.xamlの暗黙的スタイル(TargetType=Button)をBasedOnする(構造変更、調査書の結論通り)。 -->
        <Style x:Key="ToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <!-- T-089回帰修正(2026-07-18、忍者実機確認): App.xaml暗黙的スタイルの既定Background
                 (Button.Static.Background=Aero2固定ライトグレー)がツールバー上で明灰色の塊として
                 浮く回帰。従来のフラット表示(下地のToolBar背景が透ける)へ戻すため、ツールバー系
                 スタイル側でTransparentを明示する(ダイアログ等の通常ボタンは標準の明灰色のまま)。 -->
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <!-- T-047殿新注文その2(2026-07-09): 単純図形(縦線・横線等)のボタンはグレー化だけでは
                 活性/無効の判別が難しいとの殿目視所見。IsEnabled=false時にボタン全体を半透明化する
                 (殿選定=Windows標準的な無効表現・濃度差で単純図形でも判別可・実装最小)。基底
                 ToolBarButtonStyle1箇所への追加のみで、継承するPlacementToolBarButtonStyle
                 (F5〜F10・部品)・1段目(新規/開く等)双方に統一適用される。 -->
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                    <!-- T-089回帰(2)完治(2026-07-18): 基底(App.xaml暗黙的スタイル)のIsEnabled
                         トリガーがBackground=Button.Disabled.Background(明灰色)を与えるため、
                         ツールバー上ではダークモードで無効ボタン群が明灰色の塊として浮く。
                         派生側トリガーで同プロパティを上書きしフラット表示(透過+Opacityのみ)を
                         維持する。 -->
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- T-083新規発見3(殿直接指摘2026-07-17): 1段目は増分2でToolBar本体の背景色のみ対応し、
             アイコンのGeometry Fill色(Path.Stroke、継承されない非継承プロパティ)はtheme非対応の
             まま据え置かれていた見落とし。2段目(PlacementToolBarIconStyle、増分6で対応済み)と
             同じパターンでDynamicResource化する。 -->
        <Style x:Key="ToolBarIconStyle" TargetType="Path">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Stroke" Value="{DynamicResource ToolBarForegroundBrush}"/>
            <Setter Property="StrokeThickness" Value="1.4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ToolBarKeyLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
            <!-- T-083(2026-07-18、忍者実機確認NG確定=docs-notes/ecad2-t083-toolbar1-label-color-verify-ninja.md):
                 ツールバー1段目のラベル文字色がダークモードで明色化されない。2段目
                 PlacementToolBarKeyLabelStyle(T-083増分6)と同型でForeground明示指定を追加する
                 (ToolBar.Foreground継承には頼らない)。 -->
            <Setter Property="Foreground" Value="{DynamicResource ToolBarForegroundBrush}"/>
        </Style>

        <!-- T-061(殿裁定(4)=ツールバーToggleButton+背景色変化、GuiEcad踏襲): ButtonとToggleButtonは
             ButtonBaseの兄弟クラスでBasedOnによる型混在継承ができないため、ToolBarButtonStyleと
             同じ寸法・無効化表現を独立定義し、IsChecked時の背景色変化のみ追加する。
             T-089(家老采配2026-07-17): App.xamlの暗黙的スタイル(TargetType=ToggleButton)を
             BasedOnし、押下フィードバックを継承する。既存IsCheckedトリガーとの競合(押下中の
             テストモードONボタン)はMultiTriggerで個別対応する(着手前調査書の指摘通り)。 -->
        <Style x:Key="TestModeToolBarButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <!-- T-089回帰修正(2026-07-18): ToolBarButtonStyle側と同じ理由でTransparentを明示。 -->
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                    <!-- T-089回帰(2)完治: ToolBarButtonStyle側と同じ理由でTransparent上書き。 -->
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{StaticResource TestModeActiveBrush}"/>
                    <!-- T-089(2026-07-18): 基底(App.xaml)のIsCheckedトリガーがBorderBrush=
                         Button.Checked.Border(青)を与えるため、フラット維持にTransparentで上書き。 -->
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
                <!-- 複合状態(押下中+チェック済み): TestModeActiveBrushを暗くした専用色で
                     「押されている」ことも分かるようにする(基底スタイルのIsPressedトリガーのみだと
                     Style.Triggers宣言順によりIsChecked=Trueが最終的に勝ち、押下フィードバックが
                     テストモード色に埋もれて見えなくなるため)。 -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsPressed" Value="True"/>
                        <Condition Property="IsChecked" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#CC5A2E00"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- 2段目(配置系)専用スタイル(T-040、殿裁定=GX様式化の対象は2段目限定)。
             1段目(新規/開く/保存等)は上記ToolBarButtonStyle等のまま据え置く。 -->
        <Style x:Key="PlacementToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolBarButtonStyle}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
        </Style>
        <Style x:Key="PlacementToolBarIconStyle" TargetType="Path" BasedOn="{StaticResource ToolBarIconStyle}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <!-- 隠密指摘(縮小で線が密集し視認性低下)への手当て。サンプル(GX画像実測)の
                 線太さ:記号幅比は約5%、現状のToolBarIconStyle継承値1.4(18相当で7.8%)は
                 縮小後に過密な印象になるため、この段のみ細く上書きする。 -->
            <Setter Property="StrokeThickness" Value="1.0"/>
            <!-- T-083増分6(家老采配2026-07-16、殿指摘): アイコン線色をダークモード連動。
                 着手当時は1段目(ToolBarIconStyle)が非対応だったため2段目専用に明示指定したが、
                 その後の新規発見3対応(コミット1648d2b)で基底ToolBarIconStyle自体にも同じ
                 DynamicResourceが設定されたため、本SetterはBasedOn継承と同値でデッドコード化
                 している(cleanup指摘、隠密2026-07-17。実害なし、明示性のため残置)。 -->
            <Setter Property="Stroke" Value="{DynamicResource ToolBarForegroundBrush}"/>
        </Style>
        <Style x:Key="PlacementToolBarKeyLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource ToolBarKeyLabelStyle}">
            <Setter Property="FontSize" Value="8"/>
            <!-- T-083増分6(殿指摘=ボタン文字色もダークモード連動): ToolBar.Foreground継承にも
                 頼らず明示指定する(2段目専用キーのため1段目には影響しない)。 -->
            <Setter Property="Foreground" Value="{DynamicResource ToolBarForegroundBrush}"/>
        </Style>

        <!-- T-099根本修正(隠密2仮説確定・家老采配2026-07-17): 配置ツールバー2段目
             (PlacementToolBarDockingManager)のみを対象に、ドッキング時はドックタグ(タブストリップ)
             を非表示、フローティング時は表示する。AvalonDock既定のAnchorablePaneControlStyle
             (AvalonDock/Themes/generic.xaml、v4.74.1一次ソースで実取得・確認済み)をコピーした派生
             スタイル。
             【経緯】当初HeaderPanel(ItemsHost、Grid.Row="1")自体をDataTriggerでVisibility=Collapsed
             にする案(PoC)を試みたが、WPFではCollapsed要素はMeasure()が早期returnし子孫が測定
             されない→ItemsHostパネルのTabItemコンテナ生成(InternalChildren初回アクセス時に発火)が
             永遠にブロックされる→TabControlの初期選択(SelectedIndex=0)もSelectedContent解決も
             コンテナ生成完了が前提のため不成立→起動直後SelectedContent=nullで2段目全体が潰れる、
             という副作用を招いた(隠密2一次ソース確認済み、dotnet/wpf UIElement.cs/Panel.cs/
             TabControl.cs)。ItemContainerStyle側でTabItem単位のVisibility制御に切り替えれば、
             HeaderPanel自体は常にVisible(コンテナ生成は正常に走る)ため同型バグを回避できる。
             Model.IsDirectlyHostedInFloatingWindow(LayoutAnchorablePane.cs、PropertyChanged通知あり
             動的追従可能・一次ソース確認済み)をItemContainerStyleのDataTriggerで判定する
             (下記ItemContainerStyle定義を参照)。DockingManager.AnchorablePaneControlStyleへ
             ローカル値として設定することで適用範囲をこのDockingManagerのみに限定する(他パネル=
             左パレット/出力/右パネルには一切影響しない、殿確認済みの対象範囲)。要件3(パネル幅の
             動的フィット)は本修正の範囲外、忍者確認後の次段階で対応する。 -->
        <Style x:Key="PlacementToolBarPaneControlStyle" TargetType="{x:Type avalonDock:LayoutAnchorablePaneControl}">
            <Setter Property="Foreground" Value="{Binding Model.Root.Manager.Foreground, RelativeSource={RelativeSource Self}}"/>
            <Setter Property="Background" Value="{Binding Model.Root.Manager.Background, RelativeSource={RelativeSource Self}}"/>
            <Setter Property="TabStripPlacement" Value="Bottom"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type avalonDock:LayoutAnchorablePaneControl}">
                        <Grid ClipToBounds="true" KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="true">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- 既定テンプレート同様、マウスイベント捕捉用の透明Border -->
                            <Border Grid.RowSpan="2" Background="Transparent"/>
                            <Border x:Name="ContentPanel" Grid.Row="0" Grid.Column="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                KeyboardNavigation.DirectionalNavigation="Contained"
                                KeyboardNavigation.TabIndex="2"
                                KeyboardNavigation.TabNavigation="Cycle">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                    Margin="{TemplateBinding Padding}"
                                    ContentSource="SelectedContent"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                            <avalonDock:AnchorablePaneTabPanel x:Name="HeaderPanel"
                                Grid.Row="1" Margin="2,0,2,2" Panel.ZIndex="1"
                                IsItemsHost="true" KeyboardNavigation.TabIndex="1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                        <Setter Property="ToolTip" Value="{Binding ToolTip}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">
                                    <Grid SnapsToDevicePixels="true">
                                        <Border x:Name="Bd"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1,0,1,1">
                                            <Grid>
                                                <ContentPresenter x:Name="Content"
                                                    HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                    VerticalAlignment="{Binding VerticalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                    ContentSource="Header"
                                                    RecognizesAccessKey="True"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="Selector.IsSelected" Value="true">
                                            <!-- T-099根本修正派生対応(隠密2指摘): フロート時にタブが
                                                 可視化されるとダークモードで白浮きするため
                                                 DynamicResource化(コンテンツ領域と同色に統一)。 -->
                                            <Setter Property="Background" Value="{DynamicResource PanelContentBackgroundBrush}"/>
                                            <Setter Property="Panel.ZIndex" Value="1"/>
                                            <Setter Property="Margin" Value="0,-1,-1,-2"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="true"/>
                                                <Condition Property="Selector.IsSelected" Value="false"/>
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                            <Setter Property="Panel.ZIndex" Value="0"/>
                                        </MultiTrigger>
                                        <!-- 新規発見(2026-07-20、殿発見バグ・忍者実測・隠密俯瞰評価、docs/ecad2-
                                             newbug-place-operation-graytext-reproduction-ninja.md): 選択中タブが
                                             配置操作等でMainContentArea全体ごと無効化されると、選択中の視認性
                                             (背景色維持)は保たれる一方、文字だけグレー化し低コントラストになる。
                                             殿裁定=選択中は無効化時も文字を見やすいまま保つ、によりMultiTrigger化し
                                             IsSelected=Trueの場合を除外する(App.xaml ListBoxItemと同一方針)。 -->
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsEnabled" Value="false"/>
                                                <Condition Property="Selector.IsSelected" Value="false"/>
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <!-- T-104増分1派生(殿裁定2026-07-20): T-099要件(2)のドッキング時ラベル
                             Collapsed+細帯(DockedDragHandle)表示化は、2タブ構成でタブ切替の目印
                             (ラベル文字)自体が常時見える必要が生じたため撤廃し、常時ラベル表示へ
                             戻す。帯はラベル自体が通常のTabItemクリック領域として機能するため
                             不要と判断し併せて削除(通常のタブヘッダーと同様、ラベルがドラッグ
                             起点になる)。 -->
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <avalonDock:LayoutAnchorableTabItem Model="{Binding}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <avalonDock:LayoutAnchorableControl Model="{Binding}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- T-100(家老采配2026-07-17、隠密根本原因調査
             docs/ecad2-t100-drag-handle-texture-root-cause-survey-onmitsu.md): ドッキング済み
             タブヘッダー(全パネル共通)に常時表示されるハッチング模様の正体は、VS2013テーマ
             パッケージ(Dirkster.AvalonDock.Themes.VS2013、一次ソースAnchorablePaneTitleの
             暗黙的スタイル)内のRectangle x:Name="DragHandleTexture"(DrawingBrush市松模様、
             Visual Studio系IDE定番の意図的な「ドラッグハンドル」意匠)。DockPanelのLastChildFill
             機構により残りスペース全部を占有するため、タイトルラベルが短い単一タブ構成の
             パネルでは常時目立つ形になる。侍の先行試行(8650a66、AvalonDock本体generic.xamlの
             AnchorablePaneTitleStyleを元にGrid列0をAuto化)は、そもそも実行時に適用される
             VS2013テーマ側の別スタイル(DockPanel構造、本体generic.xamlとは無関係)を標的にできて
             いなかったため無効だった(標的の取り違え)。本スタイルはVS2013テーマの暗黙的スタイル
             (AvalonDock.Themes.VS2013、一次ソース確認済み)を完全コピーし、DragHandleTextureの
             Visibility="Collapsed"化のみを行う(増分7・T-099と同じ「既定コピー+標的差し替え」
             手法)。StaticResource参照(DropDownControlArea/AvalonDockThemeVs2013ToolButtonStyle/
             AvalonDockThemeVs2013ButtonStyle、いずれもVS2013テーマ内部専用キー)はコピー先では
             解決できないためDynamicResourceへ変更。ToolTip文字列(x:Static
             avalonDockProperties:Resources.*)は増分7・旧T-100同様、AvalonDock.Properties名前空間が
             XmlnsDefinition未公開のため固定の日本語文字列に置換(機能に影響なし、補助説明のみ)。
             MainWindow.xaml.csのApplyDockingManagerThemesから、Theme適用直後に各DockingManagerの
             Resources[typeof(AnchorablePaneTitle)]へ本スタイルを直接登録し、VS2013テーマの
             MergedDictionaries経由スタイルより優先させる。 -->
        <Style x:Key="AnchorablePaneTitleNoDragHandleStyle" TargetType="{x:Type avalonDock:AnchorablePaneTitle}">
            <Setter Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionInactiveBackground}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionInactiveText}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid Margin="2,2,3,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle
                                    x:Name="DragHandleGeometryPlaceholder"
                                    Fill="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionInactiveGrip}}"
                                    Visibility="Collapsed"/>
                                <DockPanel>
                                    <Border
                                        Padding="2,0,4,0"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Background}">
                                        <avalonDock:DropDownControlArea
                                            DropDownContextMenu="{Binding Model.Root.Manager.AnchorableContextMenu, RelativeSource={RelativeSource TemplatedParent}}"
                                            DropDownContextMenuDataContext="{Binding Path=LayoutItem, RelativeSource={RelativeSource TemplatedParent}}"
                                            Style="{DynamicResource DropDownControlArea}">
                                            <ContentPresenter
                                                x:Name="Header"
                                                Content="{Binding Model, RelativeSource={RelativeSource TemplatedParent}}"
                                                ContentTemplate="{Binding Model.Root.Manager.AnchorableTitleTemplate, RelativeSource={RelativeSource TemplatedParent}}"
                                                ContentTemplateSelector="{Binding Model.Root.Manager.AnchorableTitleTemplateSelector, RelativeSource={RelativeSource TemplatedParent}}"
                                                TextElement.Foreground="{TemplateBinding Foreground}"/>
                                        </avalonDock:DropDownControlArea>
                                    </Border>
                                    <!-- T-100本体: ハッチング模様の実体(DrawingBrush市松模様)を非表示化 -->
                                    <Rectangle
                                        x:Name="DragHandleTexture"
                                        Height="5"
                                        Margin="4,0,2,0"
                                        VerticalAlignment="Center"
                                        UseLayoutRounding="True"
                                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                                        Visibility="Collapsed">
                                        <Rectangle.Fill>
                                            <DrawingBrush
                                                TileMode="Tile"
                                                Viewbox="0,0,4,4"
                                                ViewboxUnits="Absolute"
                                                Viewport="0,0,4,4"
                                                ViewportUnits="Absolute">
                                                <DrawingBrush.Drawing>
                                                    <GeometryDrawing Brush="{Binding Fill, ElementName=DragHandleGeometryPlaceholder, Mode=OneWay, Converter={avalonDock:NullToDoNothingConverter}}">
                                                        <GeometryDrawing.Geometry>
                                                            <GeometryGroup>
