<Window x:Class="Ecad2.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ecad2.App"
        xmlns:views="clr-namespace:Ecad2.App.Views"
        xmlns:converters="clr-namespace:Ecad2.App.Converters"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:vs2013Themes="clr-namespace:AvalonDock.Themes.VS2013.Themes;assembly=AvalonDock.Themes.VS2013"
        mc:Ignorable="d"
        Title="ecad2" Height="800" Width="1280" WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        Closing="Window_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBool"/>
        <converters:DiagnosticSeverityToBrushConverter x:Key="SeverityToBrush"/>
        <converters:DiagnosticSeverityToTextConverter x:Key="SeverityToText"/>
        <converters:ToolModeToTextConverter x:Key="ToolModeToText"/>
        <converters:DeviceClassToTextConverter x:Key="DeviceClassToText"/>
        <converters:CircuitRefListToTextConverter x:Key="LocationsToText"/>
        <converters:StringEqualsMultiConverter x:Key="StringEqualsMultiConverter"/>

        <!-- ツールバーボタン共通スタイル: アイコン(Path)+F-key/ショートカット表示を縦積みにする
             (GX Works3実機調査T-012: マウス操作とキーボードショートカットの視覚的一体案内)。
             アイコンの絵柄は段階3では簡易プレースホルダ(Path Geometry)。本格意匠はT-013。 -->
        <!-- T-089(家老采配2026-07-17): 押下フィードバック叩き台をアプリ全体へ波及させるため
             App.xamlの暗黙的スタイル(TargetType=Button)をBasedOnする(構造変更、調査書の結論通り)。 -->
        <Style x:Key="ToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <!-- T-089回帰修正(2026-07-18、忍者実機確認): App.xaml暗黙的スタイルの既定Background
                 (Button.Static.Background=Aero2固定ライトグレー)がツールバー上で明灰色の塊として
                 浮く回帰。従来のフラット表示(下地のToolBar背景が透ける)へ戻すため、ツールバー系
                 スタイル側でTransparentを明示する(ダイアログ等の通常ボタンは標準の明灰色のまま)。 -->
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <!-- T-047殿新注文その2(2026-07-09): 単純図形(縦線・横線等)のボタンはグレー化だけでは
                 活性/無効の判別が難しいとの殿目視所見。IsEnabled=false時にボタン全体を半透明化する
                 (殿選定=Windows標準的な無効表現・濃度差で単純図形でも判別可・実装最小)。基底
                 ToolBarButtonStyle1箇所への追加のみで、継承するPlacementToolBarButtonStyle
                 (F5〜F10・部品)・1段目(新規/開く等)双方に統一適用される。 -->
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                    <!-- T-089回帰(2)完治(2026-07-18): 基底(App.xaml暗黙的スタイル)のIsEnabled
                         トリガーがBackground=Button.Disabled.Background(明灰色)を与えるため、
                         ツールバー上ではダークモードで無効ボタン群が明灰色の塊として浮く。
                         派生側トリガーで同プロパティを上書きしフラット表示(透過+Opacityのみ)を
                         維持する。 -->
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- T-083新規発見3(殿直接指摘2026-07-17): 1段目は増分2でToolBar本体の背景色のみ対応し、
             アイコンのGeometry Fill色(Path.Stroke、継承されない非継承プロパティ)はtheme非対応の
             まま据え置かれていた見落とし。2段目(PlacementToolBarIconStyle、増分6で対応済み)と
             同じパターンでDynamicResource化する。 -->
        <Style x:Key="ToolBarIconStyle" TargetType="Path">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Stroke" Value="{DynamicResource ToolBarForegroundBrush}"/>
            <Setter Property="StrokeThickness" Value="1.4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ToolBarKeyLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
            <!-- T-083(2026-07-18、忍者実機確認NG確定=docs-notes/ecad2-t083-toolbar1-label-color-verify-ninja.md):
                 ツールバー1段目のラベル文字色がダークモードで明色化されない。2段目
                 PlacementToolBarKeyLabelStyle(T-083増分6)と同型でForeground明示指定を追加する
                 (ToolBar.Foreground継承には頼らない)。 -->
            <Setter Property="Foreground" Value="{DynamicResource ToolBarForegroundBrush}"/>
        </Style>

        <!-- T-061(殿裁定(4)=ツールバーToggleButton+背景色変化、GuiEcad踏襲): ButtonとToggleButtonは
             ButtonBaseの兄弟クラスでBasedOnによる型混在継承ができないため、ToolBarButtonStyleと
             同じ寸法・無効化表現を独立定義し、IsChecked時の背景色変化のみ追加する。
             T-089(家老采配2026-07-17): App.xamlの暗黙的スタイル(TargetType=ToggleButton)を
             BasedOnし、押下フィードバックを継承する。既存IsCheckedトリガーとの競合(押下中の
             テストモードONボタン)はMultiTriggerで個別対応する(着手前調査書の指摘通り)。 -->
        <Style x:Key="TestModeToolBarButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <!-- T-089回帰修正(2026-07-18): ToolBarButtonStyle側と同じ理由でTransparentを明示。 -->
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                    <!-- T-089回帰(2)完治: ToolBarButtonStyle側と同じ理由でTransparent上書き。 -->
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{StaticResource TestModeActiveBrush}"/>
                    <!-- T-089(2026-07-18): 基底(App.xaml)のIsCheckedトリガーがBorderBrush=
                         Button.Checked.Border(青)を与えるため、フラット維持にTransparentで上書き。 -->
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
                <!-- 複合状態(押下中+チェック済み): TestModeActiveBrushを暗くした専用色で
                     「押されている」ことも分かるようにする(基底スタイルのIsPressedトリガーのみだと
                     Style.Triggers宣言順によりIsChecked=Trueが最終的に勝ち、押下フィードバックが
                     テストモード色に埋もれて見えなくなるため)。 -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsPressed" Value="True"/>
                        <Condition Property="IsChecked" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#CC5A2E00"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- 2段目(配置系)専用スタイル(T-040、殿裁定=GX様式化の対象は2段目限定)。
             1段目(新規/開く/保存等)は上記ToolBarButtonStyle等のまま据え置く。 -->
        <Style x:Key="PlacementToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolBarButtonStyle}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <!-- T-101(殿裁定2026-07-21、視覚表現=背景色+枠線の併用): 現在有効なツール
                 (ViewModel.Tool)に対応するボタンをカーソル位置に依存せず恒久ハイライトする
                 (従来はMouseOver/Pressedの一時的な色変化のみで、カーソルを離すと選択中でも
                 通常色に戻っていた=T-101起票の欠落)。ActiveToolTag(ViewModel算出プロパティ)と
                 ボタン自身のTagが一致する場合に発火する。Styleは全PlacementToolBarButtonStyle
                 ボタンで共有されるため、ConverterParameterではなくMultiBinding+
                 RelativeSource Selfでボタンごとに異なるDataContext.ActiveToolTag/Tagを個別
                 評価する。派生Style側のTriggerは基底(ToolBarButtonStyle→App.xaml暗黙的
                 Buttonスタイル)のMouseOver/Pressedトリガー(いずれもStyle.Triggers、優先度6位
                 同士だが派生が後勝ち)より優先されるため、選択中は常時ハイライトを維持する
                 (T-089 IsEnabled上書きの実証パターンと同型)。Tag未設定のボタン(接続点記入・
                 配線分断記入=即時実行でTool.Modeを変更しないツール)はActiveToolTag側にも
                 対応する値が無いため恒久ハイライトの対象外(常にfalse)。 -->
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource StringEqualsMultiConverter}">
                            <Binding Path="DataContext.ActiveToolTag" RelativeSource="{RelativeSource Self}"/>
                            <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{DynamicResource PlacementToolActiveBackgroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PlacementToolActiveBorderBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PlacementToolBarIconStyle" TargetType="Path" BasedOn="{StaticResource ToolBarIconStyle}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <!-- 隠密指摘(縮小で線が密集し視認性低下)への手当て。サンプル(GX画像実測)の
                 線太さ:記号幅比は約5%、現状のToolBarIconStyle継承値1.4(18相当で7.8%)は
                 縮小後に過密な印象になるため、この段のみ細く上書きする。 -->
            <Setter Property="StrokeThickness" Value="1.0"/>
            <!-- T-083増分6(家老采配2026-07-16、殿指摘): アイコン線色をダークモード連動。
                 着手当時は1段目(ToolBarIconStyle)が非対応だったため2段目専用に明示指定したが、
                 その後の新規発見3対応(コミット1648d2b)で基底ToolBarIconStyle自体にも同じ
                 DynamicResourceが設定されたため、本SetterはBasedOn継承と同値でデッドコード化
                 している(cleanup指摘、隠密2026-07-17。実害なし、明示性のため残置)。 -->
            <Setter Property="Stroke" Value="{DynamicResource ToolBarForegroundBrush}"/>
        </Style>
        <Style x:Key="PlacementToolBarKeyLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource ToolBarKeyLabelStyle}">
            <Setter Property="FontSize" Value="8"/>
            <!-- T-083増分6(殿指摘=ボタン文字色もダークモード連動): ToolBar.Foreground継承にも
                 頼らず明示指定する(2段目専用キーのため1段目には影響しない)。 -->
            <Setter Property="Foreground" Value="{DynamicResource ToolBarForegroundBrush}"/>
        </Style>

        <!-- T-099根本修正(隠密2仮説確定・家老采配2026-07-17): 配置ツールバー2段目
             (PlacementToolBarDockingManager)のみを対象に、ドッキング時はドックタグ(タブストリップ)
             を非表示、フローティング時は表示する。AvalonDock既定のAnchorablePaneControlStyle
             (AvalonDock/Themes/generic.xaml、v4.74.1一次ソースで実取得・確認済み)をコピーした派生
             スタイル。
             【経緯】当初HeaderPanel(ItemsHost、Grid.Row="1")自体をDataTriggerでVisibility=Collapsed
             にする案(PoC)を試みたが、WPFではCollapsed要素はMeasure()が早期returnし子孫が測定
             されない→ItemsHostパネルのTabItemコンテナ生成(InternalChildren初回アクセス時に発火)が
             永遠にブロックされる→TabControlの初期選択(SelectedIndex=0)もSelectedContent解決も
             コンテナ生成完了が前提のため不成立→起動直後SelectedContent=nullで2段目全体が潰れる、
             という副作用を招いた(隠密2一次ソース確認済み、dotnet/wpf UIElement.cs/Panel.cs/
             TabControl.cs)。ItemContainerStyle側でTabItem単位のVisibility制御に切り替えれば、
             HeaderPanel自体は常にVisible(コンテナ生成は正常に走る)ため同型バグを回避できる。
             Model.IsDirectlyHostedInFloatingWindow(LayoutAnchorablePane.cs、PropertyChanged通知あり
             動的追従可能・一次ソース確認済み)をItemContainerStyleのDataTriggerで判定する
             (下記ItemContainerStyle定義を参照)。
             T-110增分1(家老采配2026-07-22): 単一DockingManagerへの統合に伴い、本スタイルは
             Manager全体のAnchorablePaneControlStyle(全アンカラブルペイン共通)へ昇格。
             単一ペイン(シート/機器表/プロパティ/出力)ではItems.Count==1トリガー(增分0修2で
             追加、VS2013テーマ標準Generic.xaml:536-540どおり)によりTabItem自体がCollapseされ
             冗長タブは出ない(增分0実機確認済み)。 -->
        <Style x:Key="UnifiedAnchorablePaneControlStyle" TargetType="{x:Type avalonDock:LayoutAnchorablePaneControl}">
            <Setter Property="Foreground" Value="{Binding Model.Root.Manager.Foreground, RelativeSource={RelativeSource Self}}"/>
            <Setter Property="Background" Value="{Binding Model.Root.Manager.Background, RelativeSource={RelativeSource Self}}"/>
            <Setter Property="TabStripPlacement" Value="Bottom"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type avalonDock:LayoutAnchorablePaneControl}">
                        <Grid ClipToBounds="true" KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="true">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- 既定テンプレート同様、マウスイベント捕捉用の透明Border -->
                            <Border Grid.RowSpan="2" Background="Transparent"/>
                            <Border x:Name="ContentPanel" Grid.Row="0" Grid.Column="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                KeyboardNavigation.DirectionalNavigation="Contained"
                                KeyboardNavigation.TabIndex="2"
                                KeyboardNavigation.TabNavigation="Cycle">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                    Margin="{TemplateBinding Padding}"
                                    ContentSource="SelectedContent"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                            <avalonDock:AnchorablePaneTabPanel x:Name="HeaderPanel"
                                Grid.Row="1" Margin="2,0,2,2" Panel.ZIndex="1"
                                IsItemsHost="true" KeyboardNavigation.TabIndex="1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                        <Setter Property="ToolTip" Value="{Binding ToolTip}"/>
                        <!-- T-106(殿裁定2026-07-21、忍者画素採取実測=docs/proposed.md P-112):
                             非選択時Backgroundは下記ControlTemplateのBorderがTemplateBinding止まり
                             (このStyle本体に既定値が無いため既定色に固定)、Foregroundは選択/非選択
                             問わずDynamicResource未指定(常時黒)だった。既存PanelHeaderBackground/
                             ForegroundBrush(DataGridColumnHeader等と同じ「パネルヘッダー領域」の
                             意味、App.xaml参照)をここでも流用しDynamicResource化する。選択中の
                             BackgroundはControlTemplate.Triggers側で別途PanelContentBackgroundBrush
                             (コンテンツ領域と同色)に上書きされる(既存、T-099根本修正派生対応)ため
                             ここでは非選択時の値として機能する。 -->
                        <Setter Property="Background" Value="{DynamicResource PanelHeaderBackgroundBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PanelHeaderForegroundBrush}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">
                                    <Grid SnapsToDevicePixels="true">
                                        <Border x:Name="Bd"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1,0,1,1">
                                            <Grid>
                                                <ContentPresenter x:Name="Content"
                                                    HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                    VerticalAlignment="{Binding VerticalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                    ContentSource="Header"
                                                    RecognizesAccessKey="True"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="Selector.IsSelected" Value="true">
                                            <!-- T-099根本修正派生対応(隠密2指摘): フロート時にタブが
                                                 可視化されるとダークモードで白浮きするため
                                                 DynamicResource化(コンテンツ領域と同色に統一)。 -->
                                            <Setter Property="Background" Value="{DynamicResource PanelContentBackgroundBrush}"/>
                                            <Setter Property="Panel.ZIndex" Value="1"/>
                                            <Setter Property="Margin" Value="0,-1,-1,-2"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="true"/>
                                                <Condition Property="Selector.IsSelected" Value="false"/>
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                            <Setter Property="Panel.ZIndex" Value="0"/>
                                        </MultiTrigger>
                                        <!-- 新規発見(2026-07-20、殿発見バグ・忍者実測・隠密俯瞰評価、docs/ecad2-
                                             newbug-place-operation-graytext-reproduction-ninja.md): 選択中タブが
                                             配置操作等でMainContentArea全体ごと無効化されると、選択中の視認性
                                             (背景色維持)は保たれる一方、文字だけグレー化し低コントラストになる。
                                             殿裁定=選択中は無効化時も文字を見やすいまま保つ、によりMultiTrigger化し
                                             IsSelected=Trueの場合を除外する(App.xaml ListBoxItemと同一方針)。 -->
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsEnabled" Value="false"/>
                                                <Condition Property="Selector.IsSelected" Value="false"/>
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <!-- T-104増分1派生(殿裁定2026-07-20): T-099要件(2)のドッキング時ラベル
                             Collapsed+細帯(DockedDragHandle)表示化は、2タブ構成でタブ切替の目印
                             (ラベル文字)自体が常時見える必要が生じたため撤廃し、常時ラベル表示へ
                             戻す。帯はラベル自体が通常のTabItemクリック領域として機能するため
                             不要と判断し併せて削除(通常のタブヘッダーと同様、ラベルがドラッグ
                             起点になる)。 -->
                        <!-- T-110增分1(增分0修2の本実装反映): VS2013テーマ標準の「Items.Count==1で
                             TabItem自体をCollapse」トリガー(一次ソースGeneric.xaml:536-540)。従来の
                             2タブ固定ペイン専用スタイルでは死文だったため省かれていたが、全ペイン
                             共通スタイルへの昇格に伴い、単一ペイン4領域(シート/機器表/プロパティ/
                             出力)に冗長な下タブが常時表示されるのを防ぐため必須となる。 -->
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TabControl}}, Path=Items.Count}" Value="1">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <avalonDock:LayoutAnchorableTabItem Model="{Binding}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <avalonDock:LayoutAnchorableControl Model="{Binding}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- T-100(家老采配2026-07-17、隠密根本原因調査
             docs/ecad2-t100-drag-handle-texture-root-cause-survey-onmitsu.md): ドッキング済み
             タブヘッダー(全パネル共通)に常時表示されるハッチング模様の正体は、VS2013テーマ
             パッケージ(Dirkster.AvalonDock.Themes.VS2013、一次ソースAnchorablePaneTitleの
             暗黙的スタイル)内のRectangle x:Name="DragHandleTexture"(DrawingBrush市松模様、
             Visual Studio系IDE定番の意図的な「ドラッグハンドル」意匠)。DockPanelのLastChildFill
             機構により残りスペース全部を占有するため、タイトルラベルが短い単一タブ構成の
             パネルでは常時目立つ形になる。侍の先行試行(8650a66、AvalonDock本体generic.xamlの
             AnchorablePaneTitleStyleを元にGrid列0をAuto化)は、そもそも実行時に適用される
             VS2013テーマ側の別スタイル(DockPanel構造、本体generic.xamlとは無関係)を標的にできて
             いなかったため無効だった(標的の取り違え)。本スタイルはVS2013テーマの暗黙的スタイル
             (AvalonDock.Themes.VS2013、一次ソース確認済み)を完全コピーし、DragHandleTextureの
             Visibility="Collapsed"化のみを行う(増分7・T-099と同じ「既定コピー+標的差し替え」
             手法)。StaticResource参照(DropDownControlArea/AvalonDockThemeVs2013ToolButtonStyle/
             AvalonDockThemeVs2013ButtonStyle、いずれもVS2013テーマ内部専用キー)はコピー先では
             解決できないためDynamicResourceへ変更。ToolTip文字列(x:Static
             avalonDockProperties:Resources.*)は増分7・旧T-100同様、AvalonDock.Properties名前空間が
             XmlnsDefinition未公開のため固定の日本語文字列に置換(機能に影響なし、補助説明のみ)。
             MainWindow.xaml.csのApplyDockingManagerThemesから、Theme適用直後にDockingManagerの
             Resources[typeof(AnchorablePaneTitle)]へ本スタイルを直接登録し、VS2013テーマの
             MergedDictionaries経由スタイルより優先させる。
             T-110增分1(家老采配2026-07-22、增分0(e)実証済み方式): 単一DockingManager統合に伴い、
             旧PlacementToolBarAnchorablePaneTitleStyle(T-099(c)案E、配置ツールバーのみラベル
             非表示)を本スタイルへ統合する。4Manager出し分け(旧ApplyDockingManagerThemesの
             manager identity判定)は成立しなくなるため、Model.ContentId分岐(下記
             ControlTemplate.Triggers末尾)へ置き換える。案E原典の条件
             (Model.Parent.IsDirectlyHostedInFloatingWindow=False=ドッキング時のみ)はそのまま
             MultiDataTriggerとして維持する(增分0 PoCレビュー軽1指摘=忠実形採用)。
             【A-6/E-3再判断(隠密着手前チェック、忍者PoC実機確認申し送り2.5)】本実装の
             PlacementToolBarDockingManagerは常時2タブ(基本機能/配置ツール)構成のためドッキング中は
             タブUI(UnifiedAnchorablePaneControlStyle)がホストしAnchorablePaneTitle自体は使われず、
             フロート時もAvalonDock標準の別コンテナ(SinglePaneContextMenu系)が使われるため、
             忍者PoC操作範囲では本分岐が発火する場面は無かった。しかし配置ツールタブをドラッグで
             他ペイン位置へ再ドッキングし単独ペイン化する操作(CanFloat="False"はフロートのみ封止、
             ペイン間移動自体は封じていない)を完全に排除できないため、削除はリスクに対し得るものが
             小さいと判断し残置する(発火しない場合の実害はゼロ、削除しても既存の1トリガー分の
             コード削減にとどまる)。 -->
        <Style x:Key="UnifiedAnchorablePaneTitleStyle" TargetType="{x:Type avalonDock:AnchorablePaneTitle}">
            <Setter Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionInactiveBackground}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionInactiveText}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid Margin="2,2,3,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle
                                    x:Name="DragHandleGeometryPlaceholder"
                                    Fill="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionInactiveGrip}}"
                                    Visibility="Collapsed"/>
                                <DockPanel>
                                    <Border
                                        Padding="2,0,4,0"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Background}">
                                        <avalonDock:DropDownControlArea
                                            DropDownContextMenu="{Binding Model.Root.Manager.AnchorableContextMenu, RelativeSource={RelativeSource TemplatedParent}}"
                                            DropDownContextMenuDataContext="{Binding Path=LayoutItem, RelativeSource={RelativeSource TemplatedParent}}"
                                            Style="{DynamicResource DropDownControlArea}">
                                            <ContentPresenter
                                                x:Name="Header"
                                                Content="{Binding Model, RelativeSource={RelativeSource TemplatedParent}}"
                                                ContentTemplate="{Binding Model.Root.Manager.AnchorableTitleTemplate, RelativeSource={RelativeSource TemplatedParent}}"
                                                ContentTemplateSelector="{Binding Model.Root.Manager.AnchorableTitleTemplateSelector, RelativeSource={RelativeSource TemplatedParent}}"
                                                TextElement.Foreground="{TemplateBinding Foreground}"/>
                                        </avalonDock:DropDownControlArea>
                                    </Border>
                                    <!-- T-100本体: ハッチング模様の実体(DrawingBrush市松模様)を非表示化 -->
                                    <Rectangle
                                        x:Name="DragHandleTexture"
                                        Height="5"
                                        Margin="4,0,2,0"
                                        VerticalAlignment="Center"
                                        UseLayoutRounding="True"
                                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                                        Visibility="Collapsed">
                                        <Rectangle.Fill>
                                            <DrawingBrush
                                                TileMode="Tile"
                                                Viewbox="0,0,4,4"
                                                ViewboxUnits="Absolute"
                                                Viewport="0,0,4,4"
                                                ViewportUnits="Absolute">
                                                <DrawingBrush.Drawing>
                                                    <GeometryDrawing Brush="{Binding Fill, ElementName=DragHandleGeometryPlaceholder, Mode=OneWay, Converter={avalonDock:NullToDoNothingConverter}}">
                                                        <GeometryDrawing.Geometry>
                                                            <GeometryGroup>
                                                                <GeometryGroup.Children>
                                                                    <RectangleGeometry Rect="0,0,1,1"/>
                                                                    <RectangleGeometry Rect="2,2,1,1"/>
                                                                </GeometryGroup.Children>
                                                            </GeometryGroup>
                                                        </GeometryDrawing.Geometry>
                                                    </GeometryDrawing>
                                                </DrawingBrush.Drawing>
                                            </DrawingBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </DockPanel>
                                <avalonDock:DropDownButton
                                    x:Name="MenuDropDownButton"
                                    Grid.Column="1"
                                    Margin="1,1,1,0"
                                    Width="15"
                                    Height="15"
                                    VerticalAlignment="Center"
                                    DropDownContextMenu="{Binding Model.Root.Manager.AnchorableContextMenu, RelativeSource={RelativeSource TemplatedParent}}"
                                    DropDownContextMenuDataContext="{Binding Path=LayoutItem, RelativeSource={RelativeSource TemplatedParent}}"
                                    Focusable="False"
                                    Style="{DynamicResource AvalonDockThemeVs2013ToolButtonStyle}"
                                    ToolTip="メニュー">
                                    <Path
                                        x:Name="PART_ImgMenuPin"
                                        Margin="0,0,0,1"
                                        Width="8"
                                        Height="8"
                                        Data="{DynamicResource PinMenu}"
                                        Fill="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveGlyph}}"
                                        Stretch="Uniform"/>
                                </avalonDock:DropDownButton>
                                <Button
                                    x:Name="PART_AutoHidePin"
                                    Grid.Column="2"
                                    Margin="1,1,1,0"
                                    Width="15"
                                    Height="15"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{Binding Path=LayoutItem.AutoHideCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                    Focusable="False"
                                    Style="{DynamicResource AvalonDockThemeVs2013ButtonStyle}"
                                    ToolTip="自動的に隠す"
                                    Visibility="{Binding Path=IsEnabled, RelativeSource={RelativeSource Self}, Mode=OneWay, Converter={avalonDock:BoolToVisibilityConverter}}">
                                    <Path
                                        x:Name="PART_ImgAutoHidePin"
                                        UseLayoutRounding="True"
                                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                                        Width="11"
                                        Height="11"
                                        Data="{DynamicResource PinAutoHide}"
                                        Fill="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveGlyph}}"
                                        Stretch="Uniform"/>
                                </Button>
                                <Button
                                    x:Name="PART_HidePin"
                                    Grid.Column="3"
                                    Margin="0,1,1,0"
                                    Width="15"
                                    Height="15"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{Binding Path=LayoutItem.HideCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                    Focusable="False"
                                    Style="{DynamicResource AvalonDockThemeVs2013ButtonStyle}"
                                    ToolTip="閉じる"
                                    Visibility="{Binding Path=IsEnabled, RelativeSource={RelativeSource Self}, Mode=OneWay, Converter={avalonDock:BoolToVisibilityConverter}}">
                                    <Path
                                        x:Name="PART_ImgHidePin"
                                        Width="10"
                                        Height="10"
                                        Margin="1,0,0,1"
                                        VerticalAlignment="Center"
                                        Data="{DynamicResource PinClose}"
                                        Fill="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveGlyph}}"
                                        Stretch="Uniform"/>
                                </Button>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Model.IsAutoHidden, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                                <Setter TargetName="PART_AutoHidePin" Property="LayoutTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Model.CanClose, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                                <Setter TargetName="PART_HidePin" Property="Command" Value="{Binding Path=LayoutItem.CloseCommand, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Setter TargetName="PART_HidePin" Property="ToolTip" Value="閉じる"/>
                            </DataTrigger>
                            <!-- Tool Window : Caption / Active -->
                            <DataTrigger Binding="{Binding Model.IsActive, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionActiveBackground}}"/>
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionActiveText}}"/>
                                <Setter TargetName="DragHandleGeometryPlaceholder" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionActiveGrip}}"/>
                            </DataTrigger>
                            <!-- Tool Window : Caption : Button / Active -->
                            <DataTrigger Binding="{Binding Model.IsActive, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                                <Setter TargetName="PART_ImgMenuPin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveGlyph}}"/>
                                <Setter TargetName="PART_ImgAutoHidePin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveGlyph}}"/>
                                <Setter TargetName="PART_ImgHidePin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveGlyph}}"/>
                            </DataTrigger>
                            <!-- Tool Window : Caption : Button / Active, hovered -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, ElementName=MenuDropDownButton}" Value="True"/>
                                    <Condition Binding="{Binding Model.IsActive, RelativeSource={RelativeSource Mode=Self}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="MenuDropDownButton" Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveHoveredBackground}}"/>
                                <Setter TargetName="MenuDropDownButton" Property="BorderBrush" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveHoveredBorder}}"/>
                                <Setter TargetName="PART_ImgMenuPin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveHoveredGlyph}}"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, ElementName=PART_AutoHidePin}" Value="True"/>
                                    <Condition Binding="{Binding Model.IsActive, RelativeSource={RelativeSource Mode=Self}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="PART_AutoHidePin" Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveHoveredBackground}}"/>
                                <Setter TargetName="PART_AutoHidePin" Property="BorderBrush" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveHoveredBorder}}"/>
                                <Setter TargetName="PART_ImgAutoHidePin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveHoveredGlyph}}"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, ElementName=PART_HidePin}" Value="True"/>
                                    <Condition Binding="{Binding Model.IsActive, RelativeSource={RelativeSource Mode=Self}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="PART_HidePin" Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveHoveredBackground}}"/>
                                <Setter TargetName="PART_HidePin" Property="BorderBrush" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveHoveredBorder}}"/>
                                <Setter TargetName="PART_ImgHidePin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActiveHoveredGlyph}}"/>
                            </MultiDataTrigger>
                            <!-- Tool Window : Caption : Button / Inactive, hovered -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, ElementName=MenuDropDownButton}" Value="True"/>
                                    <Condition Binding="{Binding Model.IsActive, RelativeSource={RelativeSource Mode=Self}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="MenuDropDownButton" Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredBackground}}"/>
                                <Setter TargetName="MenuDropDownButton" Property="BorderBrush" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredBorder}}"/>
                                <Setter TargetName="PART_ImgMenuPin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredGlyph}}"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, ElementName=PART_AutoHidePin}" Value="True"/>
                                    <Condition Binding="{Binding Model.IsActive, RelativeSource={RelativeSource Mode=Self}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="PART_AutoHidePin" Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredBackground}}"/>
                                <Setter TargetName="PART_AutoHidePin" Property="BorderBrush" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredBorder}}"/>
                                <Setter TargetName="PART_ImgAutoHidePin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredGlyph}}"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, ElementName=PART_HidePin}" Value="True"/>
                                    <Condition Binding="{Binding Model.IsActive, RelativeSource={RelativeSource Mode=Self}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="PART_HidePin" Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredBackground}}"/>
                                <Setter TargetName="PART_HidePin" Property="BorderBrush" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredBorder}}"/>
                                <Setter TargetName="PART_ImgHidePin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredGlyph}}"/>
                            </MultiDataTrigger>
                            <!-- Tool Window : Caption : Button / Active / Inactive, pressed -->
                            <Trigger SourceName="MenuDropDownButton" Property="IsChecked" Value="True">
                                <Setter TargetName="MenuDropDownButton" Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActivePressedBackground}}"/>
                                <Setter TargetName="MenuDropDownButton" Property="BorderBrush" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActivePressedBorder}}"/>
                                <Setter TargetName="PART_ImgMenuPin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActivePressedGlyph}}"/>
                            </Trigger>
                            <Trigger SourceName="PART_AutoHidePin" Property="IsMouseCaptured" Value="True">
                                <Setter TargetName="PART_AutoHidePin" Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActivePressedBackground}}"/>
                                <Setter TargetName="PART_AutoHidePin" Property="BorderBrush" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActivePressedBorder}}"/>
                                <Setter TargetName="PART_ImgAutoHidePin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActivePressedGlyph}}"/>
                            </Trigger>
                            <Trigger SourceName="PART_HidePin" Property="IsMouseCaptured" Value="True">
                                <Setter TargetName="PART_HidePin" Property="Background" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActivePressedBackground}}"/>
                                <Setter TargetName="PART_HidePin" Property="BorderBrush" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActivePressedBorder}}"/>
                                <Setter TargetName="PART_ImgHidePin" Property="Fill" Value="{DynamicResource {x:Static vs2013Themes:ResourceKeys.ToolWindowCaptionButtonActivePressedGlyph}}"/>
                            </Trigger>
                            <!-- T-110增分1(旧PlacementToolBarAnchorablePaneTitleStyle統合、T-099(c)案E踏襲):
                                 ドッキング時、配置ツールバー(ContentId="PlacementToolBar")のみラベル
                                 (Header)を非表示にする。MenuDropDownButton等のボタン列は無変更で
                                 常時表示・操作可能に残す(案E原典どおり)。 -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Model.ContentId, RelativeSource={RelativeSource Mode=Self}}" Value="PlacementToolBar"/>
                                    <Condition Binding="{Binding Model.Parent.IsDirectlyHostedInFloatingWindow, RelativeSource={RelativeSource Mode=Self}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Header" Property="Visibility" Value="Collapsed"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayoutGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- メニューバー -->
            <RowDefinition Height="*"/>     <!-- 単一DockingManager(旧ツールバー/メイン作業域/出力パネルを内包) -->
            <RowDefinition Height="Auto"/>  <!-- ステータスバー -->
        </Grid.RowDefinitions>

        <!-- T-033増分2(隠密再レビュー改善事項): Menu/単一DockingManagerのIsEnabledバインドを
             本ラッパーGrid一箇所へ一元化。ルートGridの行0-1(メニュー〜単一DockingManager)を
             RowSpanでそのまま束ね、内部に同じ行構成(Auto/*)を持たせる。配置バー
             (ElementPlacementBar)・ステータスバーはこのラッパーの外に残し、常時有効のままとする
             (殿裁定=バー自身とステータスバーはグレーアウト対象外)。
             T-110增分1(家老采配2026-07-22): 4分割DockingManager(ツールバー/左パレット/右パネル/
             出力パネル)を単一MainDockingManagerへ統合したことに伴い、旧5行構成
             (Auto/Auto/*(Min200)/Auto/160(Min80)、ツールバー段・メイン作業域・GridSplitter・
             出力パネル段を個別行として持っていた)をAuto(メニューバー)/*(単一DockingManager、
             Min200維持)の2行へ単純化する。GridSplitter4本は全廃(AvalonDock内蔵リサイザーへ委譲)。
             ラッパー自身のGrid.RowSpanは4→2、ルートGrid(RootLayoutGrid)自体も5行→3行(メニュー/
             単一DockingManager/ステータスバー)。旧注意書き(T-033増分2位置バグ、RowSpanによる
             Auto行潰れとMainWorkAreaGrid原点ズレ)は、MainWorkAreaGrid自体が撤去され単一
             DockingManagerに置き換わったため実害の対象が消滅している——ElementPlacementBar等の
             座標変換(PositionPlacementBar)は新設のCanvasDocumentGrid(キャンバスDocument内包
             コンテナ)基準へ書き換える(下記参照)。 -->
        <Grid x:Name="MainContentArea" Grid.Row="0" Grid.RowSpan="2"
              IsEnabled="{Binding IsMainContentEnabled}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="200"/>
            </Grid.RowDefinitions>

        <!-- メニューバー: 最小限の項目構成(GX Works3同様のクラシックメニュー) -->
        <!-- T-083増分7初回(2026-07-16、殿指摘)で発覚した「白地に白文字」の根本原因は、ドロップダウン
             全体の背景(SubMenuBorder)がWPF既定Aero2テーマ内でStaticResource参照されておりDynamicResource
             オーバーライドが原理的に届かない構造的制約だった(検証ミスではない、隠密再調査書
             docs/ecad2-t083-zoubun7-menu-dark-redesign-survey-onmitsu.md)。App.xamlでComponentResourceKey
             による派生ControlTemplate(TopLevelHeaderTemplateKey/SubmenuItemTemplateKey)を新設して
             ドロップダウン側を解決した後、ここでBackground/Foregroundを復活させる(2026-07-17、
             T-083増分7再挑戦)。 -->
        <Menu x:Name="MenuBarArea" Grid.Row="0"
              Background="{DynamicResource MenuBarBackgroundBrush}"
              Foreground="{DynamicResource MenuBarForegroundBrush}">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規(_N)" InputGestureText="Ctrl+N" Click="NewButton_Click"/>
                <MenuItem Header="開く(_O)" InputGestureText="Ctrl+O" Click="OpenButton_Click"/>
                <MenuItem Header="上書き保存(_S)" InputGestureText="Ctrl+S" Click="SaveButton_Click" IsEnabled="{Binding HasProject}"/>
                <MenuItem Header="名前を付けて保存(_A)..." Click="SaveAsMenuItem_Click" IsEnabled="{Binding HasProject}"/>
                <Separator/>
                <MenuItem Header="PDF出力(_P)" InputGestureText="Ctrl+P" Click="PdfExportMenuItem_Click" IsEnabled="{Binding HasProject}"/>
                <Separator/>
                <MenuItem Header="終了(_X)"/>
            </MenuItem>
            <MenuItem Header="編集(_E)">
                <MenuItem Header="元に戻す(_U)" InputGestureText="Ctrl+Z" Command="{Binding UndoCommand}"/>
                <MenuItem Header="やり直し(_R)" InputGestureText="Ctrl+Y" Command="{Binding RedoCommand}"/>
                <Separator/>
                <MenuItem Header="切り取り(_T)" InputGestureText="Ctrl+X"/>
                <MenuItem Header="コピー(_C)" InputGestureText="Ctrl+C"/>
                <MenuItem Header="貼り付け(_P)" InputGestureText="Ctrl+V"/>
                <Separator/>
                <MenuItem Header="削除(_D)" InputGestureText="Delete" Click="DeleteMenuItem_Click"
                          IsEnabled="{Binding CanEditDiagram}"/>
            </MenuItem>
            <MenuItem Header="図面(_D)">
                <MenuItem Header="ドキュメント情報(_I)" Click="DocumentInfoMenuItem_Click" IsEnabled="{Binding HasProject}"/>
                <!-- T-064(殿裁定): 挿入トリガー=メニューのみ(ツールバーボタン新設なし)。 -->
                <MenuItem Header="画像挿入(_M)..." Click="InsertImageMenuItem_Click" IsEnabled="{Binding CanEditDiagram}"/>
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="グリッド表示(_G)" IsCheckable="True" IsChecked="{Binding IsGridVisible, Mode=TwoWay}" InputGestureText="Ctrl+G"/>
                <!-- T-083 PoC(家老采配2026-07-15、殿指示済み配置): 作図キャンバス色のテーマ切替。
                     メニュー配置はここに確定済み、起動時既定・OSテーマ追従・永続化等はPoC後に殿確認。 -->
                <MenuItem Header="ダークモード(作図色)(_D)" IsCheckable="True" IsChecked="{Binding IsDarkMode, Mode=TwoWay}"/>
                <Separator/>
                <!-- T-058増分4(殿裁定=保存タイミング両方の1つ、明示コマンド): 現在のパネルレイアウト
                     (左パレット・出力パネル・右パネル)を既定として%AppData%配下へ保存する。
                     Ctrl+Alt+R(リセット)と対をなすキーバインド。 -->
                <MenuItem Header="現在のレイアウトを既定として保存(_L)" InputGestureText="Ctrl+Alt+S" Click="SaveDockingLayoutMenuItem_Click"/>
            </MenuItem>
