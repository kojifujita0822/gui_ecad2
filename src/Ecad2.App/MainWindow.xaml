<Window x:Class="Ecad2.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ecad2.App"
        mc:Ignorable="d"
        Title="ecad2" Height="800" Width="1280" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- メニューバー(段階3で実装) -->
            <RowDefinition Height="Auto"/>  <!-- ツールバー(段階3で実装) -->
            <RowDefinition Height="*"/>     <!-- メイン作業域 -->
            <RowDefinition Height="Auto"/>  <!-- 下部出力パネル -->
            <RowDefinition Height="Auto"/>  <!-- ステータスバー -->
        </Grid.RowDefinitions>

        <!-- メニューバー領域(プレースホルダ。段階3で実装) -->
        <Border x:Name="MenuBarArea" Grid.Row="0" BorderBrush="Gray" BorderThickness="0,0,0,1" Height="24"/>

        <!-- ツールバー領域(プレースホルダ。段階3で実装) -->
        <Border x:Name="ToolBarArea" Grid.Row="1" BorderBrush="Gray" BorderThickness="0,0,0,1" Height="32"/>

        <!-- メイン作業域: 左パレット / 中央キャンバス / 右パネル -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPaletteColumn" Width="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="RightPanelColumn" Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- 左パレット: 部品選択(段階5で実装) -->
            <Border x:Name="LeftPaletteArea" Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,0"/>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

            <!-- 中央キャンバス: 図面描画(段階4で実装) -->
            <Border x:Name="CanvasArea" Grid.Column="2"/>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"/>

            <!-- 右パネル: 機器表/プロパティ(段階6で実装) -->
            <Border x:Name="RightPanelArea" Grid.Column="4" BorderBrush="Gray" BorderThickness="1,0,0,0"/>
        </Grid>

        <!-- 下部出力パネル(段階7で実装) -->
        <Border x:Name="OutputPanelArea" Grid.Row="3" BorderBrush="Gray" BorderThickness="0,1,0,0" Height="160"/>

        <!-- ステータスバー(段階7で実装) -->
        <Border x:Name="StatusBarArea" Grid.Row="4" BorderBrush="Gray" BorderThickness="0,1,0,0" Height="24"/>
    </Grid>
</Window>
