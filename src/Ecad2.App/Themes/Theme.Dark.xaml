<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework">
    <!--
        T-083増分2(層C=UIクローム基盤、家老采配2026-07-16): ダークテーマの配色定義。
        WorkAreaBackgroundBrush/EmptyStateBackgroundBrushは層A(Ecad2.Core.Rendering.DrawingTheme.Dark)
        のBackground(#FF202224)・GridColor(#FF464A50)と値を揃え、テーマ全体の一貫性を保つ。
    -->
    <SolidColorBrush x:Key="EmptyStateBackgroundBrush" Color="#FF202224"/>
    <SolidColorBrush x:Key="WorkAreaBackgroundBrush" Color="#FF202224"/>
    <SolidColorBrush x:Key="WorkAreaGridBrush" Color="#FF464A50"/>
    <!-- T-061由来の意味色(通電/励磁と同一)。テーマ非依存のためLightと同値。 -->
    <SolidColorBrush x:Key="TestModeActiveBrush" Color="#E63C00"/>

    <!-- T-083増分2新規: メニュー・ツールバー本体の配色。 -->
    <SolidColorBrush x:Key="MenuBarBackgroundBrush" Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="MenuBarForegroundBrush" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="ToolBarBackgroundBrush" Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="ToolBarForegroundBrush" Color="#FFF0F0F0"/>

    <!-- T-083増分2で試行したSystemColors系キーのオーバーライドは「白地に白文字」実害が判明し
         削除した(詳細はTheme.Light.xaml参照)。 -->

    <!-- T-083増分3新規: 各種ダイアログ・固定色パネルの配色。 -->
    <SolidColorBrush x:Key="DialogBackgroundBrush" Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="DialogForegroundBrush" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="DialogBorderBrush" Color="#FF565656"/>

    <!-- T-083増分3差し戻し(2026-07-16、忍者実機確認NG=観点3、詳細はTheme.Light.xaml参照)。
         ダイアログ背景(#FF2D2D30)よりやや明るくし、入力可能領域であることを視覚的に区別する。 -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FF3C3C3C"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#FFF0F0F0"/>

    <!-- T-083増分5新規(家老采配2026-07-17、詳細はTheme.Light.xaml参照)。
         DialogBackgroundBrush/DialogBorderBrushと値を揃え、他の暗色パネルとの統一感を保つ。 -->
    <SolidColorBrush x:Key="PanelContentBackgroundBrush" Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="PanelContentForegroundBrush" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="PanelContentSelectedBackgroundBrush" Color="#FF0E639C"/>
    <SolidColorBrush x:Key="PanelContentSelectedForegroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="PanelHeaderBackgroundBrush" Color="#FF3E3E42"/>
    <SolidColorBrush x:Key="PanelHeaderForegroundBrush" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="PanelGridLineBrush" Color="#FF565656"/>
</ResourceDictionary>
