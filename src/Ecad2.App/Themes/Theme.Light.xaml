<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework">
    <!--
        T-083増分2(層C=UIクローム基盤、家老采配2026-07-16): ライトテーマの配色定義。
        既存App.xamlの4ブラシ(GX Works3実機調査T-012由来)をそのまま踏襲する。
    -->
    <SolidColorBrush x:Key="EmptyStateBackgroundBrush" Color="#24325A"/>
    <SolidColorBrush x:Key="WorkAreaBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="WorkAreaGridBrush" Color="#D2D2D2"/>
    <!-- T-061由来の意味色(通電/励磁と同一)。テーマ非依存だがLight/Dark両辞書に同値を持たせ、
         4ブラシの統合方針(隠密調査書)に揃える。 -->
    <SolidColorBrush x:Key="TestModeActiveBrush" Color="#E63C00"/>

    <!-- T-083増分2新規: メニュー・ツールバー本体の配色。WPF既定(SystemColors)相当の明るい配色。 -->
    <SolidColorBrush x:Key="MenuBarBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="MenuBarForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ToolBarBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ToolBarForegroundBrush" Color="#000000"/>

    <!-- T-083増分2で試行したSystemColors系キーのオーバーライドは、殿実機確認(2026-07-16)で
         IsCheckable="True"のMenuItem(グリッド表示・ダークモード等)のみ文字色オーバーライドが
         作用し、背景オーバーライドは作用しないため「白地に白文字で文字が見えない」実害が
         判明し、削除した(T-083増分7、家老裁量)。メニュー背景色の暗色化は引き続き保留。 -->

    <!-- T-083増分3新規: 各種ダイアログ(AddSheetDialog等)・固定色パネル(FindBar/ElementPlacementBar/
         RungCommentEditor)の配色。 -->
    <SolidColorBrush x:Key="DialogBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="DialogForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="DialogBorderBrush" Color="Gray"/>

    <!-- T-083増分3差し戻し(2026-07-16、忍者実機確認NG=観点3): TextBox入力欄はBackground/Foreground
         未指定だとWPF既定(白背景)のままダーク時に浮いて見える。ダイアログ・固定色パネル内の
         入力欄向けに専用キーを新設する。 -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#000000"/>

    <!-- T-083増分5新規(家老采配2026-07-17): ペイン内コンテンツ(ListBox/DataGrid)の配色。
         対象=シート一覧(SheetNavList)・機器表(DeviceTableGrid)・出力/検索結果(OutputGrid/
         FindResultsGrid)・部品選択(PartSelectionList)。既定値のまま(白)だった箇所を
         DynamicResource化する(調査書「追記2」対応表)。 -->
    <SolidColorBrush x:Key="PanelContentBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="PanelContentForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="PanelContentSelectedBackgroundBrush" Color="#FF0078D7"/>
    <SolidColorBrush x:Key="PanelContentSelectedForegroundBrush" Color="White"/>
    <SolidColorBrush x:Key="PanelHeaderBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="PanelHeaderForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="PanelGridLineBrush" Color="#D2D2D2"/>

    <!-- T-083増分7新規(家老采配2026-07-17、隠密調査書=zoubun7-menu-dark-redesign-survey):
         ドロップダウンメニューのControlTemplate派生用。値はWPF既定Aero2テーマ(Menu.xaml)の
         対応キーをそのまま踏襲する(Menu.Static.Border/Separator/Disabled.Foreground/
         MenuItem.Highlight.Background/Border/Highlight.Disabled.Background/Border)。
         MenuBarBackgroundBrush/MenuBarForegroundBrush(既存、増分2定義)はポップアップ背景・
         チェックマーク色として再利用する。 -->
    <SolidColorBrush x:Key="MenuPopupBorderBrush" Color="#FF999999"/>
    <SolidColorBrush x:Key="MenuSeparatorBrush" Color="#FFD7D7D7"/>
    <SolidColorBrush x:Key="MenuDisabledForegroundBrush" Color="#FF707070"/>
    <SolidColorBrush x:Key="MenuItemAccentBackgroundBrush" Color="#3D26A0DA"/>
    <SolidColorBrush x:Key="MenuItemAccentBorderBrush" Color="#FF26A0DA"/>
    <SolidColorBrush x:Key="MenuItemHighlightDisabledBackgroundBrush" Color="#0A000000"/>
    <SolidColorBrush x:Key="MenuItemHighlightDisabledBorderBrush" Color="#21000000"/>

    <!-- T-101新規(殿裁定2026-07-21): 配置ツールバー恒久ハイライト用。PanelContentSelectedBackgroundBrush
         (#FF0078D7)と同系色で選択系統の統一感を保ちつつ、背景は半透明にしてアイコンの視認性を
         確保し、枠線は不透明ではっきり示す(MenuItemAccentBackgroundBrush/Borderと同系の設計)。 -->
    <SolidColorBrush x:Key="PlacementToolActiveBackgroundBrush" Color="#4D0078D7"/>
    <SolidColorBrush x:Key="PlacementToolActiveBorderBrush" Color="#FF0078D7"/>

    <!-- T-106(7)新規(殿裁定2026-07-21): ScrollBar用。Aero2既定値をそのまま踏襲。 -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#FFCDCDCD"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#FFA6A6A6"/>
    <SolidColorBrush x:Key="ScrollBarButtonHoverBrush" Color="#FFDADADA"/>

    <!-- T-111新規(殿指摘2026-07-22): ステータスバー警告文字色。ライトモードは現状のDarkRedを維持
         (殿指摘は「ダークモード時」限定のため)。 -->
    <SolidColorBrush x:Key="WarningMessageBrush" Color="#FF8B0000"/>

    <!-- T-119新規(殿直接指示2026-07-22、配置ツールバータブのAeroテーマ風形状変更): 縦グラデーション。
         AvalonDock.Themes.Aero原色(#FCFDFE→#D2E6FA等)そのままの流用はせず、既存パレット
         (PanelHeaderBackgroundBrush=#F0F0F0/PanelContentBackgroundBrush=White)を基準にした
         バリエーションとする。 -->
    <LinearGradientBrush x:Key="PlacementTabBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#FAFAFA"/>
        <GradientStop Offset="1" Color="#E5E5E5"/>
    </LinearGradientBrush>
    <!-- T-119往復3周目(殿実機確認2026-07-22、強調色変更): 水色系(往復2周目)から濃いグレー系へ
         差し替え。非選択(PlacementTabBackgroundBrush=#FAFAFA〜#E5E5E5)より明確に濃い色合いとし、
         枠線のアクセントカラー(PlacementTabSelectedBorderBrush、青系)との組み合わせで視認性を
         確保する(既定Foreground=黒系でも判別できる濃度に留める)。 -->
    <LinearGradientBrush x:Key="PlacementTabSelectedBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#D8D8D8"/>
        <GradientStop Offset="1" Color="#BEBEBE"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="PlacementTabBorderBrush" Color="#BFBFBF"/>
    <!-- T-119往復2周目追加要望: 選択中タブの外周枠線をアクセントカラーで目立たせる。
         PlacementToolActiveBorderBrush(T-101)と同値を流用し、既存のアクセント色体系と統一する。 -->
    <SolidColorBrush x:Key="PlacementTabSelectedBorderBrush" Color="#FF0078D7"/>
</ResourceDictionary>
