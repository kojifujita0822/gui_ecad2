<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework">
    <!--
        T-083増分2(層C=UIクローム基盤、家老采配2026-07-16): ライトテーマの配色定義。
        既存App.xamlの4ブラシ(GX Works3実機調査T-012由来)をそのまま踏襲する。
    -->
    <SolidColorBrush x:Key="EmptyStateBackgroundBrush" Color="#24325A"/>
    <SolidColorBrush x:Key="WorkAreaBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="WorkAreaGridBrush" Color="#D2D2D2"/>
    <!-- T-061由来の意味色(通電/励磁と同一)。テーマ非依存だがLight/Dark両辞書に同値を持たせ、
         4ブラシの統合方針(隠密調査書)に揃える。 -->
    <SolidColorBrush x:Key="TestModeActiveBrush" Color="#E63C00"/>

    <!-- T-083増分2新規: メニュー・ツールバー本体の配色。WPF既定(SystemColors)相当の明るい配色。 -->
    <SolidColorBrush x:Key="MenuBarBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="MenuBarForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ToolBarBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ToolBarForegroundBrush" Color="#000000"/>

    <!-- T-083増分2で試行したSystemColors系キーのオーバーライドは、殿実機確認(2026-07-16)で
         IsCheckable="True"のMenuItem(グリッド表示・ダークモード等)のみ文字色オーバーライドが
         作用し、背景オーバーライドは作用しないため「白地に白文字で文字が見えない」実害が
         判明し、削除した(T-083増分7、家老裁量)。メニュー背景色の暗色化は引き続き保留。 -->

    <!-- T-083増分3新規: 各種ダイアログ(AddSheetDialog等)・固定色パネル(FindBar/ElementPlacementBar/
         RungCommentEditor)の配色。 -->
    <SolidColorBrush x:Key="DialogBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="DialogForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="DialogBorderBrush" Color="Gray"/>

    <!-- T-083増分3差し戻し(2026-07-16、忍者実機確認NG=観点3): TextBox入力欄はBackground/Foreground
         未指定だとWPF既定(白背景)のままダーク時に浮いて見える。ダイアログ・固定色パネル内の
         入力欄向けに専用キーを新設する。 -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#000000"/>

    <!-- T-083増分5新規(家老采配2026-07-17): ペイン内コンテンツ(ListBox/DataGrid)の配色。
         対象=シート一覧(SheetNavList)・機器表(DeviceTableGrid)・出力/検索結果(OutputGrid/
         FindResultsGrid)・部品選択(PartSelectionList)。既定値のまま(白)だった箇所を
         DynamicResource化する(調査書「追記2」対応表)。 -->
    <SolidColorBrush x:Key="PanelContentBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="PanelContentForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="PanelContentSelectedBackgroundBrush" Color="#FF0078D7"/>
    <SolidColorBrush x:Key="PanelContentSelectedForegroundBrush" Color="White"/>
    <SolidColorBrush x:Key="PanelHeaderBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="PanelHeaderForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="PanelGridLineBrush" Color="#D2D2D2"/>
</ResourceDictionary>
