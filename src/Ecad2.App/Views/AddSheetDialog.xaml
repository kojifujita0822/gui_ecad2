<Window x:Class="Ecad2.App.Views.AddSheetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="シート追加" Height="210" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource DialogBackgroundBrush}"
        Foreground="{DynamicResource DialogForegroundBrush}">
    <StackPanel Margin="12">
        <TextBlock Text="シート名:" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" Margin="0,0,0,12"/>
        <TextBlock Text="種別:" Margin="0,0,0,4"/>
        <RadioButton x:Name="ControlCircuitRadio" Content="制御回路" GroupName="SheetType"
                     IsChecked="True" Margin="0,0,0,4"/>
        <RadioButton x:Name="MainCircuitRadio" Content="主回路" GroupName="SheetType"
                     Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="70" IsDefault="True" Click="OkButton_Click"/>
            <Button Content="キャンセル" Width="70" IsCancel="True" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
