<Window x:Class="Ecad2.App.Views.ElementPlacementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="要素の配置" Height="180" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="12">
        <TextBlock Text="種別:" Margin="0,0,0,4"/>
        <ComboBox x:Name="PartComboBox" DisplayMemberPath="Definition.Name" Margin="0,0,0,12"/>
        <TextBlock Text="デバイス名:" Margin="0,0,0,4"/>
        <TextBox x:Name="DeviceNameBox" Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="70" IsDefault="True" Click="OkButton_Click"/>
            <Button Content="キャンセル" Width="70" IsCancel="True" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
