<Window x:Class="Ecad2.App.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="シート名の変更" Height="140" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="12">
        <TextBlock Text="新しいシート名:" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="70" IsDefault="True" Click="OkButton_Click"/>
            <Button Content="キャンセル" Width="70" IsCancel="True" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
